---
export interface Props {
  color?: string;
  size?: string;
  style?: string;
  mobile?: boolean;
}

const { color = "#FFCCE4", size = "198px", mobile = false } = Astro.props;
---

<div
  class={`star-float ${mobile ? "" : "hidden md:block"} pointer-events-none`}
  style={`width: ${size}; height: ${size}; ${Astro.props.style || ""}`}
>
  <svg viewBox="0 0 100 100" fill={color} stroke="#000000" stroke-width="1" class="w-full h-full">
    <polygon points="50,5 63,38 98,38 70,60 79,95 50,75 21,95 30,60 2,38 37,38" />
  </svg>
</div>
