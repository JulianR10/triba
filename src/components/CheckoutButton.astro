---
interface Props {
  provider: "stripe" | "mercadopago";
  currency: "EUR" | "USD" | "ARS";
  variant?: "primary" | "default" | "ghost";
  size?: "sm" | "md";
  label?: string;
  fullWidth?: boolean;
}

const { provider, currency, variant = "primary", size = "md", label, fullWidth } = Astro.props;
const displayLabel = label || `${provider === "stripe" ? "Tarjeta (Stripe)" : provider === "mercadopago" ? "Mercado Pago" : "Pagar"}`;
const btnClass = `
  inline-flex items-center justify-center font-heading uppercase tracking-wider transition-all duration-200 hover:scale-[1.02]
  ${fullWidth ? "w-full" : ""}
  ${variant === "primary"
    ? "bg-triba-red text-triba-white border-2 border-triba-red rounded-button"
    : variant === "default"
    ? "bg-triba-white text-triba-black border-2 border-triba-black rounded-button"
    : "bg-transparent text-triba-black border-2 border-triba-black rounded-button"}
  ${size === "sm" ? "px-6 py-2.5 text-xs" : "px-8 py-3 text-sm"}
`;
---

<button type="button" data-provider={provider} data-currency={currency} class={btnClass} data-magnetic>
  {displayLabel}
</button>
<p class="font-sans text-xs text-triba-red text-center mt-1 hidden" data-checkout-error></p>

<script>
  import { supabase } from "../lib/supabase";
  import { saveCheckoutIntent } from "../lib/checkout-intent";

  function attachCheckoutHandlers() {
    document.querySelectorAll("button[data-provider]").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const provider = btn.getAttribute("data-provider");
        const currency = btn.getAttribute("data-currency");
        const originalText = btn.textContent;

        const errorEl = btn.parentElement?.querySelector("[data-checkout-error]");
        if (errorEl) errorEl.classList.add("hidden");
        (btn as HTMLButtonElement).disabled = true;
        btn.textContent = "Procesando...";

        try {
          if (!supabase) throw new Error("Supabase no configurado");
          const { data: { session } } = await supabase.auth.getSession();
          if (!session) {
            saveCheckoutIntent(provider!, currency!);
            const redirect = encodeURIComponent(window.location.pathname + "?currency=" + currency);
            window.location.href = "/iniciar-sesion?redirect=" + redirect;
            return;
          }

          const res = await fetch("/api/create-checkout", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              Authorization: `Bearer ${session.access_token}`,
            },
            body: JSON.stringify({ provider, currency }),
          });
          const data = await res.json();
          if (data.url) window.location.href = data.url;
          else throw new Error(data.error || "Error creando checkout");
        } catch (err: any) {
          const errorEl = btn.parentElement?.querySelector("[data-checkout-error]");
          if (errorEl) {
            errorEl.textContent = err.message || "Error al procesar el pago. Intentalo de nuevo.";
            errorEl.classList.remove("hidden");
          }
          btn.textContent = originalText;
          (btn as HTMLButtonElement).disabled = false;
        }
      });
    });
  }

  attachCheckoutHandlers();
  document.addEventListener("astro:page-load", attachCheckoutHandlers);
</script>
