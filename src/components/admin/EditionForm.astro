---
import Input from "../Input.astro";
import Button from "../Button.astro";
import { isStorageConfigured } from "../../lib/storage";
import type { Edition } from "../../lib/editions";

interface Props {
  mode: "create" | "edit";
  edition?: Edition | null;
}

const { mode, edition } = Astro.props;
const storageReady = isStorageConfigured();
const formId = `edition-form-${mode}`;
const formMsgId = "form-msg";
---

<form id={formId} data-edition-id={edition?.id ?? ""} data-mode={mode} class="space-y-6">
  <div class="grid md:grid-cols-2 gap-4">
    <Input
      label="Número de edición"
      name="edition_number"
      type="number"
      required
      minlength={1}
      placeholder="1"
      value={edition?.edition_number?.toString() ?? ""}
      validationMsg="Ingresá un número entero positivo"
    />
    <Input
      label="Badge (opcional)"
      name="badge"
      type="text"
      placeholder="Última edición"
      value={edition?.badge ?? ""}
    />
  </div>

  <Input
    label="Título"
    name="title"
    type="text"
    required
    placeholder="Tomo 1 — Identidades"
    value={edition?.title ?? ""}
  />

  <div>
    <label for="description" class="block font-heading text-xs uppercase tracking-wider text-triba-brown mb-1">Descripción</label>
    <textarea
      id="description"
      name="description"
      rows="5"
      required
      placeholder="Resumen de la edición. Se muestra en la home y en la portada del PDF."
      class="w-full px-4 py-3 rounded-button border-2 border-triba-black bg-triba-white font-sans text-sm text-triba-brown outline-none focus:border-triba-red transition-colors resize-none"
    >{edition?.description ?? ""}</textarea>
  </div>

  <div class="grid md:grid-cols-2 gap-6">
    <div>
      <p class="block font-heading text-xs uppercase tracking-wider text-triba-brown mb-2">Portada (imagen)</p>
      <div class="border-2 border-dashed border-triba-black/30 rounded-xl p-4 bg-triba-bone">
        {edition?.cover_url && (
          <img id="cover-preview" src={edition.cover_url} alt="Portada actual" class="w-32 h-auto mx-auto mb-3 rounded border border-triba-black/20" />
        )}
        <input
          type="file"
          name="cover_file"
          accept="image/jpeg,image/png,image/webp,image/avif"
          class="font-sans text-xs w-full"
        />
        <p class="font-sans text-xs text-triba-brown/60 mt-2">JPG/PNG/WebP/AVIF, máx 5 MB. Si no subís archivo nuevo, se conserva la portada actual.</p>
      </div>
    </div>

    <div>
      <p class="block font-heading text-xs uppercase tracking-wider text-triba-brown mb-2">PDF (opcional)</p>
      <div class="border-2 border-dashed border-triba-black/30 rounded-xl p-4 bg-triba-bone">
        {edition?.pdf_url && (
          <p class="font-sans text-xs text-triba-brown/70 mb-2">PDF actual: <a href={edition.pdf_url} class="text-triba-red hover:underline" target="_blank" rel="noopener">ver</a></p>
        )}
        <input
          type="file"
          name="pdf_file"
          accept="application/pdf"
          class="font-sans text-xs w-full"
        />
        <p class="font-sans text-xs text-triba-brown/60 mt-2">PDF, máx 80 MB. Si no subís archivo nuevo, se conserva el actual.</p>
      </div>
    </div>
  </div>

  <input type="hidden" name="existing_cover_url" value={edition?.cover_url ?? ""} />
  <input type="hidden" name="existing_pdf_url" value={edition?.pdf_url ?? ""} />

  <label class="flex items-center gap-3 p-4 rounded-xl border-2 border-triba-black/20 bg-triba-white cursor-pointer hover:border-triba-black">
    <input
      type="checkbox"
      name="featured"
      value="true"
      checked={!!edition?.featured}
      class="w-5 h-5 accent-triba-red"
    />
    <div>
      <p class="font-heading text-sm uppercase tracking-wider text-triba-brown">Marcar como edición destacada</p>
      <p class="font-sans text-xs text-triba-brown/60">Solo puede haber una a la vez. Quita el destaque de la anterior automáticamente.</p>
    </div>
  </label>

  {!storageReady && (
    <p class="font-sans text-xs text-triba-red bg-triba-red/10 border border-triba-red rounded p-3">
      ⚠️ Storage no está configurado. Vas a tener que pegar URLs externas para cover y PDF.
    </p>
  )}

  <div class="flex flex-wrap items-center gap-3 pt-2">
    <Button type="submit" variant="primary">{mode === "create" ? "Crear edición" : "Guardar cambios"}</Button>
    <a href="/admin/ediciones" class="rounded-button bg-triba-bone text-triba-brown border-2 border-triba-black px-6 py-3 font-heading text-xs uppercase tracking-wider hover:scale-[1.02] transition-all">Cancelar</a>
    {mode === "edit" && (
      <button
        type="button"
        id="delete-edition-btn"
        data-edition-id={edition?.id}
        data-edition-number={edition?.edition_number}
        class="ml-auto rounded-button bg-transparent text-triba-red border-2 border-triba-red px-6 py-3 font-heading text-xs uppercase tracking-wider hover:bg-triba-red hover:text-triba-white transition-all"
      >
        Eliminar
      </button>
    )}
  </div>

  <p id={formMsgId} class="font-sans text-sm hidden"></p>
</form>

<script>
  function setupEditionForm() {
    const form = document.querySelector<HTMLFormElement>("form[id^=edition-form-]");
    if (!form) return;
    const msg = document.getElementById("form-msg");
    if (!msg) return;
    const submitBtn = form.querySelector<HTMLButtonElement>("button[type=submit]");
    if (!submitBtn) return;
    const mode = form.dataset.mode;

    if ((form as any)._editionFormBound) return;
    (form as any)._editionFormBound = true;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      msg.classList.add("hidden");
      msg.textContent = "";
      msg.className = "font-sans text-sm hidden";

      const fd = new FormData(form);
      submitBtn.disabled = true;
      submitBtn.textContent = mode === "create" ? "Creando..." : "Guardando...";

      try {
        const editionId = form.dataset.editionId;
        const url = mode === "create"
          ? "/api/admin/editions"
          : `/api/admin/editions/${editionId}`;
        const method = mode === "create" ? "POST" : "PATCH";

        const res = await fetch(url, { method, body: fd });
        const data = await res.json().catch(() => ({}));

        if (!res.ok) {
          msg.textContent = data.error || "Error guardando la edición";
          msg.className = "font-sans text-sm text-triba-red bg-triba-red/10 border border-triba-red rounded p-3";
          msg.classList.remove("hidden");
          (window as any).adminToast?.(data.error || "Error guardando la edición", "error");
          return;
        }

        (window as any).adminToast?.(mode === "create" ? "Edición creada" : "Edición actualizada", "success");
        setTimeout(() => { window.location.href = "/admin/ediciones"; }, 800);
      } catch (err) {
        msg.textContent = "Error de conexión. Intentalo de nuevo.";
        msg.className = "font-sans text-sm text-triba-red bg-triba-red/10 border border-triba-red rounded p-3";
        msg.classList.remove("hidden");
        (window as any).adminToast?.("Error de conexión", "error");
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = mode === "create" ? "Crear edición" : "Guardar cambios";
      }
    });

    const deleteBtn = document.getElementById("delete-edition-btn") as HTMLButtonElement | null;
    if (deleteBtn) {
      deleteBtn.addEventListener("click", async () => {
        const id = deleteBtn.dataset.editionId;
        const num = deleteBtn.dataset.editionNumber;
        const confirmed = await (window as any).adminConfirm?.(
          "Eliminar edición",
          `¿Eliminar la edición #${num}? Esta acción no se puede deshacer.`
        );
        if (!confirmed) return;
        deleteBtn.disabled = true;
        deleteBtn.textContent = "Eliminando...";
        try {
          const res = await fetch(`/api/admin/editions/${id}`, { method: "DELETE" });
          const data = await res.json().catch(() => ({}));
          if (!res.ok) {
            (window as any).adminToast?.(data.error || "Error eliminando", "error");
            deleteBtn.disabled = false;
            deleteBtn.textContent = "Eliminar";
            return;
          }
          (window as any).adminToast?.("Edición eliminada", "success");
          setTimeout(() => { window.location.href = "/admin/ediciones"; }, 800);
        } catch (err) {
          (window as any).adminToast?.("Error de conexión", "error");
          deleteBtn.disabled = false;
          deleteBtn.textContent = "Eliminar";
        }
      });
    }
  }

  setupEditionForm();
  document.addEventListener("astro:page-load", setupEditionForm);
</script>
