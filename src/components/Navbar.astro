---
import { createSupabaseServerClient } from "../lib/supabase-server";

const supabase = createSupabaseServerClient(Astro.request);
const {
  data: { session },
} = await supabase.auth.getSession();
const isLoggedIn = !!session;

const publicLinks = [
  { href: "/", label: "Inicio" },
  { href: "/revista", label: "Revista" },
  { href: "/suscribirme", label: "Suscribirme" },
  { href: "/triba-creators", label: "Triba Creators" },
];

const authLinks = [
  { href: "/mi-cuenta", label: "Mi perfil" },
  { href: "/revista", label: "Revista" },
  { href: "/triba-creators", label: "Triba Creators" },
];
---

<style>
  :root {
    --nav-height: calc(64px + env(safe-area-inset-top, 0px));
  }

  .slide-in {
    transform: translateX(0);
  }

  #navbar {
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    padding-top: calc(1rem + env(safe-area-inset-top));
  }

  #menu-toggle {
    top: calc(1rem + env(safe-area-inset-top));
  }

  #mobile-menu {
    padding-top: env(safe-area-inset-top);
    padding-bottom: env(safe-area-inset-bottom);
  }

  #navbar.nav-hidden {
    transform: translateY(-100%);
  }

  #mi-cuenta-dropdown {
    transform-origin: top right;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  #mi-cuenta-dropdown.hidden {
    opacity: 0;
    transform: scale(0.95);
    pointer-events: none;
  }

  #mi-cuenta-dropdown:not(.hidden) {
    opacity: 1;
    transform: scale(1);
    pointer-events: auto;
  }
</style>

<nav id="navbar" class="hidden md:flex fixed top-0 left-0 right-0 z-40 items-center px-5 py-4 md:px-10 lg:px-20 bg-triba-bone/80 backdrop-blur-sm">
  <div class="flex items-center justify-between w-full max-w-6xl mx-auto">
    <a href="/" class="shrink-0">
      <img src="/logo-triba.svg" alt="Triba" class="h-9 transition-transform duration-300 hover:scale-110" />
    </a>

    <div class="flex items-center gap-8">
      {
        isLoggedIn
          ? authLinks.map((link) => (
              <a
                href={link.href}
                class="font-heading text-sm font-medium uppercase tracking-wide text-triba-red transition-colors hover:text-triba-brown focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-triba-red focus-visible:ring-offset-2 rounded"
              >
                {link.label}
              </a>
            ))
          : publicLinks.filter((l) => l.label !== "Inicio").map((link) => (
              <a
                href={link.href}
                class="font-heading text-sm font-medium uppercase tracking-wide text-triba-red transition-colors hover:text-triba-brown focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-triba-red focus-visible:ring-offset-2 rounded"
              >
                {link.label}
              </a>
            ))
      }
    </div>

    {
      isLoggedIn
        ? <div class="relative">
            <button id="mi-cuenta-btn" class="rounded-button bg-triba-red px-6 py-2.5 font-heading text-sm font-medium uppercase text-triba-white border-2 border-triba-black transition-all hover:scale-[1.02] active:scale-[0.98] flex items-center gap-2">
              MI CUENTA
              <svg class="w-3 h-3 fill-current" viewBox="0 0 10 6"><path d="M0 0l5 6 5-6z"/></svg>
            </button>
            <div id="mi-cuenta-dropdown" class="hidden absolute right-0 top-full mt-2 w-64 bg-triba-white border-2 border-triba-black rounded-xl shadow-xl overflow-hidden z-50">
              <div class="p-4" id="mi-cuenta-content">
                <div class="flex items-center justify-center py-4">
                  <div class="w-5 h-5 border-2 border-triba-red border-t-2 border-t-transparent rounded-full animate-spin"></div>
                </div>
              </div>
            </div>
          </div>
        : <a href="/iniciar-sesion" class="rounded-button bg-triba-red px-6 py-2.5 font-heading text-sm font-medium uppercase text-triba-white border-2 border-triba-black transition-all hover:scale-[1.02] active:scale-[0.98]">INICIAR SESION</a>
    }
  </div>
</nav>

<button id="menu-toggle" class="fixed top-4 right-4 z-50 md:hidden flex flex-col gap-1.5 p-3.5 bg-gradient-to-br from-triba-pink to-triba-white shadow-lg border-none cursor-pointer" style="clip-path: polygon(5% 0%, 100% 3%, 97% 93%, 0% 100%)" aria-label="Menu">
  <span class="h-0.5 w-7 bg-triba-black block transition-all duration-300 origin-center"></span>
  <span class="h-0.5 w-7 bg-triba-black block transition-all duration-300"></span>
  <span class="h-0.5 w-7 bg-triba-black block transition-all duration-300 origin-center"></span>
</button>

<div id="menu-overlay" class="fixed inset-0 z-40 bg-black/40 hidden md:hidden"></div>

<div id="mobile-menu" class="fixed top-0 right-0 z-40 h-full w-80 max-w-[85vw] bg-triba-white shadow-2xl flex flex-col md:hidden translate-x-full transition-transform duration-300">
  <div class="flex items-center justify-between px-6 py-5 border-b border-triba-black/10">
    <a href="/"><img src="/logo-triba.svg" alt="Triba" class="h-8" /></a>
  </div>

  <div class="flex-1 flex flex-col gap-1 px-6 pt-6">
    {
      (isLoggedIn ? authLinks : publicLinks.filter((l) => l.label !== "Inicio")).map((link) => (
        <a
          href={link.href}
          class="font-heading text-lg font-medium uppercase tracking-wide text-triba-red py-3 border-b border-triba-black/10 transition-colors hover:text-triba-brown focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-triba-red focus-visible:ring-inset"
        >
          {link.label}
        </a>
      ))
    }

    {
      isLoggedIn && (
        <div id="mobile-mi-cuenta-items" class="border-b border-triba-black/10 py-3 space-y-3">
          <div class="flex items-center justify-center py-2">
            <div class="w-4 h-4 border-2 border-triba-red border-t-2 border-t-transparent rounded-full animate-spin"></div>
          </div>
        </div>
      )
    }
  </div>

  <div class="px-6 pb-8 pt-4 border-t border-triba-black/10">
    {
      isLoggedIn
        ? <button id="logout-btn-mobile" class="rounded-button bg-triba-red px-6 py-3 font-heading text-sm font-medium uppercase text-triba-white border-2 border-triba-black transition-all hover:scale-[1.02] active:scale-[0.98] w-full block text-center">CERRAR SESION</button>
        : <a href="/iniciar-sesion" class="rounded-button bg-triba-red px-6 py-3 font-heading text-sm font-medium uppercase text-triba-white border-2 border-triba-black transition-all hover:scale-[1.02] active:scale-[0.98] w-full block text-center">INICIAR SESION</a>
    }
  </div>
</div>

<script>
  import { supabase } from "../lib/supabase";
  import { showConfirm } from "./admin/AdminUI";

  var lastSubStatus = null;

  function setupNav() {
    if (window._navScrollHandler) {
      window.removeEventListener("scroll", window._navScrollHandler);
    }
    if (window._navObserver) {
      window._navObserver.disconnect();
    }

    var nav = document.getElementById("navbar");
    if (!nav) return;

    var root = document.documentElement;

    function updateNavHeight() {
      root.style.setProperty("--nav-height", nav.offsetHeight + "px");
    }

    updateNavHeight();

    var lastScrollY = window.scrollY;
    var tickingNav = false;

    function onNavScroll() {
      if (!tickingNav) {
        requestAnimationFrame(function () {
          var currentScrollY = window.scrollY;
          var menuOpen = document.getElementById("mobile-menu") &&
            !document.getElementById("mobile-menu").classList.contains("translate-x-full");

          if (!menuOpen && currentScrollY > 80) {
            if (currentScrollY > lastScrollY) {
              nav.classList.add("nav-hidden");
            } else {
              nav.classList.remove("nav-hidden");
            }
          } else {
            nav.classList.remove("nav-hidden");
          }

          lastScrollY = currentScrollY;
          tickingNav = false;
        });
        tickingNav = true;
      }
    }

    if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      window._navScrollHandler = onNavScroll;
      window.addEventListener("scroll", onNavScroll, { passive: true });
    }

    var observer = new ResizeObserver(updateNavHeight);
    window._navObserver = observer;
    observer.observe(nav);

    var toggle = document.getElementById("menu-toggle");
    var menu = document.getElementById("mobile-menu");
    var overlay = document.getElementById("menu-overlay");
    var spans = toggle ? toggle.querySelectorAll("span") : [];
    var isOpen = false;

    function openMenu() {
      isOpen = true;
      overlay.classList.remove("hidden");
      menu.classList.remove("translate-x-full");
      menu.classList.add("slide-in");
      document.body.style.overflow = "hidden";
      if (spans.length === 3) {
        spans[0].style.transform = "rotate(45deg) translate(5px, 5px)";
        spans[1].style.opacity = "0";
        spans[2].style.transform = "rotate(-45deg) translate(5px, -5px)";
      }
    }

    function closeMenu() {
      isOpen = false;
      menu.classList.add("translate-x-full");
      menu.classList.remove("slide-in");
      overlay.classList.add("hidden");
      document.body.style.overflow = "";
      if (spans.length === 3) {
        spans[0].style.transform = "";
        spans[1].style.opacity = "";
        spans[2].style.transform = "";
      }
    }

    if (toggle) {
      toggle.addEventListener("click", function () {
        if (isOpen) {
          closeMenu();
        } else {
          openMenu();
        }
      });
    }

    if (overlay) {
      overlay.addEventListener("click", closeMenu);
    }

    if (menu) {
      menu.querySelectorAll("a").forEach(function (link) {
        link.addEventListener("click", closeMenu);
      });
    }

    // --- MI CUENTA dropdown ---
    setupMiCuentaDropdown();

    // --- Logout ---
    async function logout() {
      if (supabase) {
        await supabase.auth.signOut();
      }
      window.location.href = "/";
    }

    var logoutBtn = document.getElementById("logout-btn-mobile");
    if (logoutBtn) logoutBtn.addEventListener("click", logout);
  }

  function setupMiCuentaDropdown() {
    // Desktop dropdown
    var btn = document.getElementById("mi-cuenta-btn");
    var dropdown = document.getElementById("mi-cuenta-dropdown");
    var content = document.getElementById("mi-cuenta-content");

    if (btn && dropdown && content) {
      if (!btn.dataset.bound) {
        btn.dataset.bound = "1";
        btn.addEventListener("click", function (e) {
          e.stopPropagation();
          var isHidden = dropdown.classList.contains("hidden");
          dropdown.classList.toggle("hidden");
          if (isHidden && !dropdown.dataset.loaded) {
            fetchSubStatus(content, dropdown);
          }
        });

        document.addEventListener("click", function (e) {
          if (!dropdown.classList.contains("hidden") &&
              !dropdown.contains(e.target) &&
              e.target !== btn &&
              !btn.contains(e.target)) {
            dropdown.classList.add("hidden");
          }
        });
      }
    }

    // Mobile items
    var mobileItems = document.getElementById("mobile-mi-cuenta-items");
    if (mobileItems && !mobileItems.dataset.bound) {
      mobileItems.dataset.bound = "1";
      fetchSubStatus(mobileItems, null);
    }
  }

  async function fetchSubStatus(container, dropdown) {
    try {
      var { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        renderGuest(container);
        if (dropdown) dropdown.dataset.loaded = "1";
        return;
      }

      var res = await fetch("/api/subscription-status", {
        headers: { Authorization: "Bearer " + session.access_token },
      });
      var data = await res.json();
      if (!res.ok) throw new Error(data.error || "Error");

      lastSubStatus = data;
      renderDropdown(container, data, dropdown);
    } catch (e) {
      container.innerHTML =
        '<p class="font-sans text-xs text-triba-red text-center">Error al cargar</p>';
    } finally {
      if (dropdown) dropdown.dataset.loaded = "1";
    }
  }

  function renderDropdown(container, data, dropdown) {
    var sub = data.subscription;
    var role = data.role;

    if (role === "admin") {
      container.innerHTML =
        '<a href="/admin" class="block w-full text-left font-heading text-xs uppercase tracking-wider text-triba-brown hover:text-triba-red py-2 transition-colors">Panel de administración →</a>' +
        '<hr class="border-triba-black/10 my-2">' +
        '<button class="logout-dropdown-btn block w-full text-left font-heading text-xs uppercase tracking-wider text-triba-red hover:text-triba-brown py-2 transition-colors">Cerrar sesión</button>';
      bindLogout(container);
      return;
    }

    if (!sub || sub.status === "none" || sub.status === "incomplete") {
      container.innerHTML =
        '<p class="font-sans text-xs text-triba-brown/70 mb-2">Aún no estás suscripta</p>' +
        '<a href="/suscribirme" class="block w-full text-center rounded-button bg-triba-red text-triba-white border-2 border-triba-black px-4 py-2 font-heading text-xs uppercase tracking-wider hover:scale-[1.02] transition-all">Suscribirme</a>' +
        '<hr class="border-triba-black/10 my-2">' +
        '<button class="logout-dropdown-btn block w-full text-left font-heading text-xs uppercase tracking-wider text-triba-red hover:text-triba-brown py-2 transition-colors">Cerrar sesión</button>';
      bindLogout(container);
      return;
    }

    if (sub.status === "canceled") {
      container.innerHTML =
        '<p class="font-heading text-xs uppercase tracking-wider text-triba-brown/60 mb-1">Suscripción cancelada</p>' +
        '<p class="font-sans text-xs text-triba-brown/50 mb-3">Ya no tenés acceso a la revista</p>' +
        '<a href="/suscribirme" class="block w-full text-center rounded-button bg-triba-red text-triba-white border-2 border-triba-black px-4 py-2 font-heading text-xs uppercase tracking-wider hover:scale-[1.02] transition-all">Suscribirme de nuevo</a>' +
        '<hr class="border-triba-black/10 my-2">' +
        '<button class="logout-dropdown-btn block w-full text-left font-heading text-xs uppercase tracking-wider text-triba-red hover:text-triba-brown py-2 transition-colors">Cerrar sesión</button>';
      bindLogout(container);
      return;
    }

    // Active subscription
    var periodEnd = sub.current_period_end
      ? new Date(sub.current_period_end).toLocaleDateString("es-AR", { day: "2-digit", month: "short", year: "numeric" })
      : "";

    container.innerHTML =
      '<a href="/mi-cuenta" class="block w-full text-left font-heading text-xs uppercase tracking-wider text-triba-red hover:text-triba-brown py-2 transition-colors">Ir a mi perfil →</a>' +
      '<hr class="border-triba-black/10 my-2">' +
      '<div class="mb-3">' +
        '<p class="font-heading text-xs uppercase tracking-wider text-triba-green mb-1">Suscripción activa</p>' +
        '<p class="font-sans text-xs text-triba-brown">' +
          'Plan <span class="font-bold">' + sub.plan_currency + '</span> vía <span class="font-bold capitalize">' + sub.provider + '</span>' +
        '</p>' +
        (periodEnd ? '<p class="font-sans text-[10px] text-triba-brown/50">Vence ' + periodEnd + '</p>' : '') +
      '</div>' +
      (sub.provider === "stripe"
        ? '<button class="manage-sub-btn block w-full text-left font-sans text-xs text-triba-brown hover:text-triba-red hover:underline py-1.5 transition-colors">Gestionar suscripción</button>'
        : '<p class="font-sans text-[10px] text-triba-brown/50 mb-1">Gestioná desde tu cuenta de Mercado Pago</p>') +
      '<button class="cancel-sub-btn block w-full text-left font-sans text-xs text-triba-red hover:underline py-1.5 transition-colors">Cancelar suscripción</button>' +
      '<hr class="border-triba-black/10 my-2">' +
      '<button class="logout-dropdown-btn block w-full text-left font-heading text-xs uppercase tracking-wider text-triba-red hover:text-triba-brown py-2 transition-colors">Cerrar sesión</button>';

    bindManage(container);
    bindCancel(container);
    bindLogout(container);
  }

  function renderGuest(container) {
    container.innerHTML =
      '<a href="/iniciar-sesion" class="block w-full text-center rounded-button bg-triba-red text-triba-white border-2 border-triba-black px-4 py-2 font-heading text-xs uppercase tracking-wider hover:scale-[1.02] transition-all">Iniciar sesión</a>';
  }

  function bindManage(container) {
    container.querySelector(".manage-sub-btn")?.addEventListener("click", async function () {
      var { data: { session } } = await supabase.auth.getSession();
      if (!session) return;
      try {
        var res = await fetch("/api/portal", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: "Bearer " + session.access_token,
          },
        });
        var data = await res.json();
        if (data.url) { window.location.href = data.url; return; }
        if (data.note) { alert(data.note); return; }
        throw new Error(data.error || "Error");
      } catch (e) {
        alert("Error al abrir el portal de gestión");
      }
    });
  }

  function bindCancel(container) {
    container.querySelector(".cancel-sub-btn")?.addEventListener("click", async function () {
      var confirmed = await showConfirm(
        "Cancelar suscripción",
        "¿Estás segura? Perderás el acceso a la revista al final del período actual."
      );
      if (!confirmed) return;

      var { data: { session } } = await supabase.auth.getSession();
      if (!session) return;

      this.disabled = true;
      this.textContent = "Cancelando...";
      try {
        var res = await fetch("/api/cancel-subscription", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: "Bearer " + session.access_token,
          },
        });
        var data = await res.json();
        if (data.ok) {
          var toast = (window as any).adminToast;
          if (toast) { toast("Suscripción cancelada", "success"); }
          if (data.providerWarnings && data.providerWarnings.length > 0) {
            var warnMsg = "Cancelada en Triba, pero hubo un problema con el proveedor de pago: " + data.providerWarnings.join(". ");
            setTimeout(function () { alert(warnMsg); }, 500);
          }
          setTimeout(function () { window.location.reload(); }, 1000);
        } else {
          alert(data.error || "Error al cancelar");
          this.disabled = false;
          this.textContent = "Cancelar suscripción";
        }
      } catch (e) {
        alert("Error de conexión");
        this.disabled = false;
        this.textContent = "Cancelar suscripción";
      }
    });
  }

  function bindLogout(container) {
    container.querySelectorAll(".logout-dropdown-btn").forEach(function (btn) {
      btn.addEventListener("click", async function () {
        if (supabase) await supabase.auth.signOut();
        window.location.href = "/";
      });
    });
  }

  setupNav();
  document.addEventListener("astro:page-load", setupNav);
</script>
