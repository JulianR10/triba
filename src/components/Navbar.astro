---
import { createSupabaseServerClient } from "../lib/supabase-server";

const supabase = createSupabaseServerClient(Astro.request);
const {
  data: { session },
} = await supabase.auth.getSession();
const isLoggedIn = !!session;

const publicLinks = [
  { href: "/", label: "Inicio" },
  { href: "/revista", label: "Revista" },
  { href: "/suscribirme", label: "Suscribirme" },
  { href: "/triba-creators", label: "Triba Creators" },
];

const authLinks = [
  { href: "/mi-cuenta", label: "Mi cuenta" },
  { href: "/revista", label: "Revista" },
];
---

<style>
  :root {
    --nav-height: 64px;
  }

  .slide-in {
    transform: translateX(0);
  }
</style>

<nav id="navbar" class="hidden md:flex fixed top-0 left-0 right-0 z-40 items-center justify-center px-5 py-4 md:px-10 lg:px-20 bg-triba-bone/80 backdrop-blur-sm">
  <div class="flex items-center gap-8">
    {
      isLoggedIn
        ? authLinks.map((link) => (
            <a
              href={link.href}
              class="font-heading text-sm font-medium uppercase tracking-wide text-triba-red transition-colors hover:text-triba-brown focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-triba-red focus-visible:ring-offset-2 rounded"
            >
              {link.label}
            </a>
          ))
        : publicLinks.map((link) => (
            <a
              href={link.href}
              class="font-heading text-sm font-medium uppercase tracking-wide text-triba-red transition-colors hover:text-triba-brown focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-triba-red focus-visible:ring-offset-2 rounded"
            >
              {link.label}
            </a>
          ))
    }
    {
      isLoggedIn
        ? <button id="logout-btn" class="rounded-button bg-triba-red px-6 py-2.5 font-heading text-sm font-medium uppercase text-triba-white border-2 border-triba-black transition-all hover:scale-[1.02] active:scale-[0.98]">CERRAR SESION</button>
        : <a href="/iniciar-sesion" class="rounded-button bg-triba-red px-6 py-2.5 font-heading text-sm font-medium uppercase text-triba-white border-2 border-triba-black transition-all hover:scale-[1.02] active:scale-[0.98]">INICIAR SESION</a>
    }
  </div>
</nav>

<button id="menu-toggle" class="fixed top-4 right-4 z-50 md:hidden flex flex-col gap-1.5 p-2" aria-label="Menu">
  <span class="h-0.5 w-7 bg-triba-black block transition-all duration-300 origin-center"></span>
  <span class="h-0.5 w-7 bg-triba-black block transition-all duration-300"></span>
  <span class="h-0.5 w-7 bg-triba-black block transition-all duration-300 origin-center"></span>
</button>

<div id="menu-overlay" class="fixed inset-0 z-40 bg-black/40 hidden md:hidden"></div>

<div id="mobile-menu" class="fixed top-0 right-0 z-40 h-full w-80 max-w-[85vw] bg-triba-bone shadow-2xl flex flex-col md:hidden translate-x-full transition-transform duration-300">
  <div class="flex items-center justify-between px-6 py-5 border-b border-triba-black/10">
    <img src="/logo-triba.svg" alt="Triba" class="h-8" />
  </div>

  <div class="flex-1 flex flex-col gap-1 px-6 pt-6">
    {
      (isLoggedIn ? authLinks : publicLinks).map((link) => (
        <a
          href={link.href}
          class="font-heading text-lg font-medium uppercase tracking-wide text-triba-red py-3 border-b border-triba-black/10 transition-colors hover:text-triba-brown focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-triba-red focus-visible:ring-inset"
        >
          {link.label}
        </a>
      ))
    }
  </div>

  <div class="px-6 pb-8 pt-4 border-t border-triba-black/10">
    {
      isLoggedIn
        ? <button id="logout-btn-mobile" class="rounded-button bg-triba-red px-6 py-3 font-heading text-sm font-medium uppercase text-triba-white border-2 border-triba-black transition-all hover:scale-[1.02] active:scale-[0.98] w-full block text-center">CERRAR SESION</button>
        : <a href="/iniciar-sesion" class="rounded-button bg-triba-red px-6 py-3 font-heading text-sm font-medium uppercase text-triba-white border-2 border-triba-black transition-all hover:scale-[1.02] active:scale-[0.98] w-full block text-center">INICIAR SESION</a>
    }
  </div>
</div>

<script>
  import { createClient } from "@supabase/supabase-js";

  const supabase = createClient(
    import.meta.env.VITE_SUPABASE_URL,
    import.meta.env.VITE_SUPABASE_ANON_KEY
  );

  function setupNav() {
    var nav = document.getElementById("navbar");
    if (!nav) return;

    var root = document.documentElement;

    function updateNavHeight() {
      root.style.setProperty("--nav-height", nav.offsetHeight + "px");
    }

    updateNavHeight();

    var observer = new ResizeObserver(updateNavHeight);
    observer.observe(nav);

    var toggle = document.getElementById("menu-toggle");
    var menu = document.getElementById("mobile-menu");
    var overlay = document.getElementById("menu-overlay");
    var spans = toggle ? toggle.querySelectorAll("span") : [];
    var isOpen = false;

    function openMenu() {
      isOpen = true;
      overlay.classList.remove("hidden");
      menu.classList.remove("translate-x-full");
      menu.classList.add("slide-in");
      document.body.style.overflow = "hidden";
      if (spans.length === 3) {
        spans[0].style.transform = "rotate(45deg) translate(5px, 5px)";
        spans[1].style.opacity = "0";
        spans[2].style.transform = "rotate(-45deg) translate(5px, -5px)";
      }
    }

    function closeMenu() {
      isOpen = false;
      menu.classList.add("translate-x-full");
      menu.classList.remove("slide-in");
      overlay.classList.add("hidden");
      document.body.style.overflow = "";
      if (spans.length === 3) {
        spans[0].style.transform = "";
        spans[1].style.opacity = "";
        spans[2].style.transform = "";
      }
    }

    if (toggle) {
      toggle.addEventListener("click", function () {
        if (isOpen) {
          closeMenu();
        } else {
          openMenu();
        }
      });
    }

    if (overlay) {
      overlay.addEventListener("click", closeMenu);
    }

    if (menu) {
      menu.querySelectorAll("a").forEach(function (link) {
        link.addEventListener("click", closeMenu);
      });
    }

    // Logout
    async function logout() {
      await supabase.auth.signOut();
      window.location.href = "/";
    }

    var logoutBtn = document.getElementById("logout-btn");
    var logoutBtnMobile = document.getElementById("logout-btn-mobile");
    if (logoutBtn) logoutBtn.addEventListener("click", logout);
    if (logoutBtnMobile) logoutBtnMobile.addEventListener("click", logout);
  }

  setupNav();
</script>
