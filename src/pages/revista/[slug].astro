---
import Layout from "../../layouts/Layout.astro";
import Button from "../../components/Button.astro";
import PageFlipViewer from "../../components/PageFlipViewer.tsx";
import { getEditionBySlug, getEditionPages } from "../../lib/editions";
import PatchTitle from "../../components/PatchTitle.astro";

const { slug } = Astro.params;
const edition = await getEditionBySlug(slug!);
const pages = edition ? await getEditionPages(edition.id) : [];

if (!edition) {
  return Astro.redirect("/revista");
}

const title = `${edition.title} — Revista`;
const description = edition.description.split("\n")[0];
const canonical = `/revista/${slug}`;
const previewPages = pages.map((p) => ({ src: p.image_url, alt: p.alt_text }));

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": edition.title,
  "description": description,
  "image": edition.cover_url,
  "datePublished": edition.created_at,
  "author": {
    "@type": "Organization",
    "name": "Triba",
    "url": "https://comunidadtriba.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Triba",
    "logo": { "@type": "ImageObject", "url": "https://comunidadtriba.com/logo-triba.svg" }
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": `https://comunidadtriba.com/revista/${slug}` }
};
---

<Layout {title} {description} {canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  <section class="py-12 md:py-24 px-5 md:px-10 lg:px-20 xl:px-32 2xl:px-48 bg-triba-bone" style="padding-top: max(1rem, var(--nav-height, 64px))">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col md:flex-row gap-8 md:gap-12 lg:gap-16 mb-16 md:mb-20 reveal" data-reveal>
        <div class="flex-1 flex flex-col justify-center">
          <p class="font-heading text-lg md:text-xl text-triba-red mb-2 uppercase tracking-wider">Edición #{edition.edition_number}</p>
          <PatchTitle content={edition.title} tag="h1" centered={false} class="text-3xl md:text-4xl text-triba-brown mb-6" />
          <p class="font-sans text-base md:text-lg text-triba-brown leading-relaxed mb-8 whitespace-pre-line">{edition.description}</p>
          <div class="flex flex-wrap gap-4">
            {previewPages.length > 1 && (
              <Button variant="primary" size="md" href="#visor-revista">Leer aquí</Button>
            )}
            {edition.pdf_url && (
              <Button variant="default" size="md" href={edition.pdf_url}>Descargar PDF</Button>
            )}
          </div>
        </div>
        <div class="flex-1">
          <div class="max-w-sm mx-auto md:mx-0">
            <img src={edition.cover_url} alt={`Portada de ${edition.title}`} loading="lazy" class="w-full rounded-xl border-2 border-triba-black shadow-lg" />
          </div>
        </div>
      </div>

      {previewPages.length > 1 && (
        <div class="mb-16 md:mb-20 reveal" id="visor-revista" style="scroll-margin-top: calc(var(--nav-height, 64px) + 1rem)" data-reveal>
          <PatchTitle content="Previsualización" tag="h2" class="text-2xl md:text-3xl text-triba-brown mb-8" />
          <PageFlipViewer pages={previewPages} client:visible />
        </div>
      )}

      <div class="text-center">
        <Button variant="default" href="/revista">Ver todas las ediciones</Button>
      </div>
    </div>
  </section>
</Layout>
