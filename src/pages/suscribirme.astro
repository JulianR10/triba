---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import CheckoutButton from "../components/CheckoutButton.astro";
import { plans } from "../lib/pricing";

const title = "Suscribirme";
const description = "Elegí tu plan de suscripción a Triba: newsletter gratuito o suscripción paga con acceso a la revista completa, archivo y descarga PDF. Pago seguro con Stripe, Mercado Pago o PayPal.";
const canonical = "/suscribirme";

const faqs = [
  { q: "¿Cuándo llega la revista?", a: "La revista se publica el primer día de cada mes. La recibís automáticamente en tu correo y en tu dashboard." },
  { q: "¿Puedo cancelar mi suscripción?", a: "Sí, podés cancelar en cualquier momento desde tu cuenta. Sin preguntas ni complicaciones." },
  { q: "¿Cómo accedo a la revista?", a: "Una vez suscripta, vas a poder leerla online desde nuestro visor o descargarla en PDF." },
];
---

<Layout title={title} description={description} canonical={canonical}>
  <section class="py-16 md:py-24 px-5 md:px-10 lg:px-20 xl:px-32 2xl:px-48 bg-triba-bone">
    <div class="max-w-6xl mx-auto">

      <div class="bg-triba-pink border-2 border-triba-black px-8 md:px-16 py-4 md:py-5 mb-10 mt-[50px] w-fit mx-auto" style="border-radius: 50%; transform: rotate(-10deg)">
        <h1 class="font-heading text-xl md:text-2xl text-triba-brown uppercase tracking-wide leading-snug text-center whitespace-nowrap">
          Nuestra suscripción
        </h1>
      </div>

      <!-- Cards de plan -->
      <div class="grid md:grid-cols-2 gap-6 mb-12">
        <div class="bg-triba-cream rounded-xl border-2 border-triba-black p-6 text-center">
          <h3 class="font-heading text-base font-bold text-triba-brown mb-3 uppercase tracking-wider">Newsletter gratuito</h3>
          <ul class="space-y-2 font-sans text-sm text-triba-brown">
            <li class="flex justify-center gap-2">✦ 2 ARTICULOS PERIODISTICOS POR MES</li>
            <li class="flex justify-center gap-2">✦ 1 ARTICULO SELECTO DE NUESTRA REVISTA</li>
          </ul>
          <p class="font-sans text-xs text-triba-brown/70 mt-4 leading-relaxed">Te llega a tu correo todos los meses, como un blog de noticias</p>
          <form class="mt-4 space-y-4" id="newsletter-form-card">
            <div class="max-w-[80%] mx-auto">
              <input type="email" name="email" required placeholder="tu@email.com" class="w-full px-4 py-3 rounded-button border-2 border-triba-black bg-triba-white font-sans text-sm text-triba-brown outline-none focus:border-triba-red transition-colors text-center" />
            </div>
            <Button variant="ghost" size="md" type="submit">Quiero el newsletter</Button>
            <p id="newsletter-card-msg" class="font-sans text-xs text-center"></p>
          </form>
        </div>
        <div class="bg-triba-pink rounded-xl border-2 border-triba-black p-6 text-center">
          <h3 class="font-heading text-lg font-bold text-triba-brown mb-3 uppercase tracking-wider">Suscripción Triba</h3>
          <ul class="space-y-2 font-sans text-sm text-triba-brown">
            <li class="flex justify-center gap-2">✦ NEWSLETTER INCLUIDO</li>
            <li class="flex justify-center gap-2">✦ REVISTA COMPLETA (+15 ARTICULOS)</li>
            <li class="flex justify-center gap-2">✦ ACCESO AL ARCHIVO DE TODAS LAS EDICIONES</li>
            <li class="flex justify-center gap-2">✦ DESCARGA LA REVISTA EN FORMATO PDF CON TU NOMBRE</li>
          </ul>
          <p class="font-sans text-xs text-triba-brown/70 mt-4 leading-relaxed text-balance">Accedes a traves de tu perfil de usuario en nuestro sitio web</p>
          <Button variant="primary" size="md" href="#precios" class="mt-4">Quiero suscribirme</Button>
        </div>
      </div>

      <!-- Social proof -->
      <div class="text-center mb-16">
        <p class="font-serif italic text-base text-triba-brown/70 max-w-lg mx-auto">
          "Somos una comunidad de mujeres que escriben para mujeres. Cada suscripción nos ayuda a seguir creciendo."
        </p>
        <p class="font-heading text-xs uppercase tracking-wider text-triba-red mt-2">— Equipo Triba</p>
      </div>

      <!-- Precios con segmented control -->
      <div id="precios" class="mb-16">
        <h2 class="font-heading text-xl uppercase tracking-wider text-triba-brown mb-8 text-center">Elegí tu moneda</h2>

        <div class="max-w-sm mx-auto">
          <div class="bg-triba-white rounded-xl border-2 border-triba-black p-8 md:p-10 text-center">
            <div class="flex border-2 border-triba-black rounded-full overflow-hidden mb-8" id="currency-segments">
              {plans.map((p, i) => (
                <button
                  data-currency={p.moneda}
                  class={"flex-1 py-3 font-heading text-xs uppercase tracking-wider transition-all " + (i < plans.length - 1 ? "border-r-2 border-triba-black " : "") + (p.moneda === "EUR" ? "bg-triba-red text-triba-white" : "bg-triba-white text-triba-brown hover:bg-triba-cream")}
                >
                  <span class="block">{p.moneda}</span>
                  <span class="block text-[10px] opacity-70 mt-0.5">{p.simbolo}{p.precio}</span>
                </button>
              ))}
            </div>

            {plans.map((p) => (
              <div data-plan={p.moneda} class={p.moneda === "EUR" ? "" : "hidden"}>
                <p class="font-heading text-5xl md:text-6xl font-bold text-triba-red mb-1">{p.simbolo}{p.precio}</p>
                <p class="font-sans text-sm text-triba-brown/60 mb-8">{p.periodo}</p>

                <!-- Métodos de pago -->
                <div class="space-y-3 mb-6">
                  <CheckoutButton provider="stripe" currency={p.moneda} fullWidth />
                  <CheckoutButton provider="mercadopago" currency={p.moneda} variant="default" fullWidth />
                  <CheckoutButton provider="paypal" currency={p.moneda} variant="ghost" fullWidth />
                </div>

                <p class="font-sans text-[11px] text-triba-brown/50">Pago único mensual. Cancelá cuando quieras.</p>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- FAQ -->
      <div>
        <h2 class="font-heading text-xl uppercase tracking-wider text-triba-brown mb-8">Preguntas frecuentes</h2>
        <div class="space-y-4 max-w-2xl">
          {faqs.map((faq) => (
            <details class="bg-triba-cream rounded-xl border-2 border-triba-black overflow-hidden group">
              <summary class="px-5 py-4 font-heading text-sm font-medium uppercase tracking-wider text-triba-brown cursor-pointer list-none flex items-center justify-between">
                {faq.q}
                <span class="text-triba-red text-lg transition-transform duration-300 group-open:rotate-45">+</span>
              </summary>
              <div class="px-5 pb-4 font-sans text-sm text-triba-brown leading-relaxed">
                {faq.a}
              </div>
            </details>
          ))}
        </div>
      </div>

    </div>
  </section>
</Layout>

<script>
  (function () {
    var tabs = document.querySelectorAll("[data-currency]");
    var plans = document.querySelectorAll("[data-plan]");

    function selectCurrency(currency) {
      tabs.forEach(function (t) {
        t.classList.remove("bg-triba-red", "text-triba-white");
        t.classList.add("bg-triba-white", "text-triba-brown");
      });
      var activeTab = document.querySelector('[data-currency="' + currency + '"]');
      if (activeTab) {
        activeTab.classList.remove("bg-triba-white", "text-triba-brown");
        activeTab.classList.add("bg-triba-red", "text-triba-white");
      }
      plans.forEach(function (p) {
        p.classList.toggle("hidden", p.dataset.plan !== currency);
      });
    }

    // Auto-select from URL param
    var urlParams = new URLSearchParams(window.location.search);
    var urlCurrency = urlParams.get("currency");
    if (urlCurrency) selectCurrency(urlCurrency);

    tabs.forEach(function (btn) {
      btn.addEventListener("click", function () {
        selectCurrency(btn.dataset.currency);
      });
    });

    // Newsletter form card
    var nf = document.getElementById("newsletter-form-card");
    var nm = document.getElementById("newsletter-card-msg");
    if (nf) {
      nf.addEventListener("submit", async function (e) {
        e.preventDefault();
        var email = nf.querySelector("input[type=email]").value;
        var res = await fetch("/api/newsletter", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email }),
        });
        var data = await res.json();
        if (data.ok) {
          nm.textContent = "¡Gracias por suscribirte!";
          nm.className = "font-sans text-xs text-center text-triba-green";
          nf.querySelector("input[type=email]").value = "";
        } else if (data.existing) {
          nm.textContent = "Ya estás suscripta";
          nm.className = "font-sans text-xs text-center text-triba-red";
        } else {
          nm.textContent = "Error al suscribirte. Intentalo de nuevo.";
          nm.className = "font-sans text-xs text-center text-triba-red";
        }
      });
    }
  })();
</script>
