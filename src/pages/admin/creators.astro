---
import AdminLayout from "../../components/admin/AdminLayout.astro";
import { listCreatorApplicationsForAdmin } from "../../lib/admin/creators";

const statusFilter = (Astro.url.searchParams.get("status") || "all") as "all" | "pending" | "approved" | "rejected";
const validFilters = ["all", "pending", "approved", "rejected"] as const;
const filter = validFilters.includes(statusFilter) ? statusFilter : "all";

const applications = await listCreatorApplicationsForAdmin(filter);

const counts = {
  all: (await listCreatorApplicationsForAdmin("all")).length,
  pending: (await listCreatorApplicationsForAdmin("pending")).length,
  approved: (await listCreatorApplicationsForAdmin("approved")).length,
  rejected: (await listCreatorApplicationsForAdmin("rejected")).length,
};
---

<AdminLayout title="Triba Creators" active="creators">
  <div class="flex gap-2 mb-6 flex-wrap">
    {[
      { key: "all", label: "Todas" },
      { key: "pending", label: "Pendientes" },
      { key: "approved", label: "Aprobadas" },
      { key: "rejected", label: "Rechazadas" },
    ].map((tab) => (
      <a
        href={tab.key === "all" ? "/admin/creators" : `/admin/creators?status=${tab.key}`}
        class={`rounded-button border-2 px-4 py-1.5 font-heading text-xs uppercase tracking-wider transition-all ${
          filter === tab.key
            ? "bg-triba-red text-triba-white border-triba-black"
            : "bg-triba-white text-triba-brown border-triba-black/20 hover:border-triba-black"
        }`}
      >
        {tab.label} ({counts[tab.key as keyof typeof counts]})
      </a>
    ))}
  </div>

  {
    applications.length === 0 ? (
      <div class="bg-triba-cream rounded-xl border-2 border-triba-black p-8 text-center">
        <p class="font-sans text-sm text-triba-brown">No hay postulaciones en esta categoría.</p>
      </div>
    ) : (
      <div class="space-y-4">
        {applications.map((a) => (
          <div class="bg-triba-white rounded-xl border-2 border-triba-black p-5">
            <div class="flex items-start justify-between gap-3 mb-3 flex-wrap">
              <div>
                <p class="font-heading text-base text-triba-brown">{a.nombre}</p>
                <p class="font-sans text-xs text-triba-brown/60">
                  {a.email} · {a.pais} ·{" "}
                  {new Date(a.created_at).toLocaleDateString("es-AR", { day: "2-digit", month: "short", year: "numeric" })}
                </p>
              </div>
              <span
                class={`inline-block px-2 py-0.5 rounded-full font-heading text-[10px] uppercase tracking-wider ${
                  a.status === "pending"
                    ? "bg-triba-light-cream text-triba-brown"
                    : a.status === "approved"
                      ? "bg-triba-green text-triba-brown"
                      : "bg-triba-bone text-triba-brown/60"
                }`}
              >
                {a.status}
              </span>
            </div>

            {a.areas.length > 0 && (
              <div class="flex flex-wrap gap-1 mb-3">
                {a.areas.map((area) => (
                  <span class="inline-block px-2 py-0.5 bg-triba-pink rounded-full font-sans text-xs text-triba-brown">{area}</span>
                ))}
              </div>
            )}

            <p class="font-sans text-sm text-triba-brown whitespace-pre-wrap mb-3">{a.propuesta}</p>

            {a.trabajo_url && (
              <p class="font-sans text-xs mb-3">
                <a href={a.trabajo_url} target="_blank" rel="noopener" class="text-triba-red hover:underline">Ver trabajo →</a>
              </p>
            )}

            {a.admin_notes && (
              <p class="font-sans text-xs text-triba-brown/60 italic mb-3 border-l-2 border-triba-brown/20 pl-3">
                Nota: {a.admin_notes}
              </p>
            )}

            {a.status === "pending" && (
              <div class="flex gap-2 pt-2 border-t border-triba-black/10">
                <button
                  class="creator-action-btn rounded-button bg-triba-green text-triba-brown border-2 border-triba-black px-4 py-2.5 min-h-[44px] font-heading text-xs uppercase tracking-wider hover:scale-[1.02] transition-all"
                  data-id={a.id}
                  data-action="approved"
                >
                  Aprobar
                </button>
                <button
                  class="creator-action-btn rounded-button bg-triba-bone text-triba-brown border-2 border-triba-black px-4 py-2.5 min-h-[44px] font-heading text-xs uppercase tracking-wider hover:scale-[1.02] transition-all"
                  data-id={a.id}
                  data-action="rejected"
                >
                  Rechazar
                </button>
              </div>
            )}
          </div>
        ))}
      </div>
    )
  }
</AdminLayout>

<script>
  function setupCreatorActions() {
    document.querySelectorAll<HTMLButtonElement>(".creator-action-btn").forEach((btn) => {
      if (btn.dataset.bound === "1") return;
      btn.dataset.bound = "1";
      btn.addEventListener("click", async () => {
        const id = btn.dataset.id;
        const action = btn.dataset.action;
        const label = action === "approved" ? "aprobar" : "rechazar";
        const confirmed = await (window as any).adminConfirm?.(
          `${label.charAt(0).toUpperCase() + label.slice(1)} postulación`,
          `¿Estás segura de que querés ${label} esta postulación?`
        );
        if (!confirmed) return;
        btn.disabled = true;
        try {
          const res = await fetch(`/api/admin/creators`, {
            method: "PATCH",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ id, status: action }),
          });
          const data = await res.json().catch(() => ({}));
          if (!res.ok) {
            (window as any).adminToast?.(data.error || "Error", "error");
            btn.disabled = false;
            return;
          }
          (window as any).adminToast?.(`Postulación ${label}`, "success");
          setTimeout(() => window.location.reload(), 800);
        } catch (err) {
          (window as any).adminToast?.("Error de conexión", "error");
          btn.disabled = false;
        }
      });
    });
  }
  setupCreatorActions();
  document.addEventListener("astro:page-load", setupCreatorActions);
</script>
