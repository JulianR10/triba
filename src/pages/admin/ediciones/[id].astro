---
import AdminLayout from "../../../components/admin/AdminLayout.astro";
import EditionForm from "../../../components/admin/EditionForm.astro";
import { getEditionForAdmin } from "../../../lib/admin/editions";

const { id } = Astro.params;
const editionId = Number(id);

if (!Number.isInteger(editionId)) {
  return Astro.redirect("/admin/ediciones");
}

const data = await getEditionForAdmin(editionId);
if (!data) {
  return Astro.redirect("/admin/ediciones");
}

const { edition, pages } = data;
---

<AdminLayout title={`Editar #${edition.edition_number} — ${edition.title}`} active="ediciones">
  <p class="font-sans text-sm text-triba-brown/70 mb-6">
    {pages.length} {pages.length === 1 ? "página" : "páginas"} asociadas.
    {edition.featured && <span class="ml-2 inline-block px-2 py-0.5 rounded-full bg-triba-green text-triba-brown font-heading text-[10px] uppercase tracking-wider">Destacada</span>}
  </p>

  <div class="bg-triba-white rounded-xl border-2 border-triba-black p-6 mb-8">
    <EditionForm mode="edit" edition={edition} />
  </div>

  <div class="bg-triba-white rounded-xl border-2 border-triba-black p-6">
    <h2 class="font-heading text-base uppercase tracking-wider text-triba-brown mb-4">Páginas del visor</h2>

    <div id="pages-upload-area" class="border-2 border-dashed border-triba-black/30 rounded-xl p-6 bg-triba-bone mb-6 text-center">
      <p class="font-sans text-sm text-triba-brown/70 mb-2">Subí imágenes de página para el visor</p>
      <p class="font-sans text-xs text-triba-brown/50 mb-4">JPG/PNG/WebP/AVIF, máx 5 MB cada una. Podés seleccionar varias.</p>
      <input
        id="pages-file-input"
        type="file"
        accept="image/jpeg,image/png,image/webp,image/avif"
        multiple
        class="hidden"
      />
      <button id="pages-upload-btn" class="rounded-button bg-triba-red text-triba-white border-2 border-triba-black px-5 py-2.5 font-heading text-xs uppercase tracking-wider hover:scale-[1.02] transition-all">Seleccionar imágenes</button>
      <p id="pages-upload-msg" class="font-sans text-xs text-triba-brown/60 mt-3 hidden"></p>
    </div>

    <div id="pages-grid" class="grid grid-cols-3 md:grid-cols-6 gap-3 min-h-[100px]">
      {pages.length === 0 ? (
        <p id="pages-empty" class="col-span-full font-sans text-sm text-triba-brown/50 text-center py-8">Todavía no hay páginas. Subí imágenes arriba.</p>
      ) : (
        pages.map((p) => (
          <div class="page-card relative group aspect-[3/4] bg-triba-bone rounded border border-triba-black/20 overflow-hidden" data-page-id={p.id} data-page-number={p.page_number}>
            <img src={p.image_url} alt={p.alt_text} class="w-full h-full object-cover" />
            <div class="absolute top-1 left-1 bg-triba-black/60 text-triba-white text-[10px] font-heading px-1.5 py-0.5 rounded">{p.page_number}</div>
            <button class="page-delete-btn absolute top-1 right-1 bg-triba-red text-triba-white w-6 h-6 rounded-full text-xs font-heading opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center" data-page-id={p.id} data-page-number={p.page_number}>×</button>
            <div class="absolute bottom-0 inset-x-0 bg-triba-black/50 p-1 opacity-0 group-hover:opacity-100 transition-opacity flex gap-1 justify-center">
              <button class="page-move-btn text-triba-white text-xs font-heading px-1" data-page-id={p.id} data-dir="prev">◀</button>
              <button class="page-move-btn text-triba-white text-xs font-heading px-1" data-page-id={p.id} data-dir="next">▶</button>
            </div>
          </div>
        ))
      )}
    </div>
  </div>
</AdminLayout>

<script>
  function setupPagesManagement() {
    const editionId = new URL(window.location.href).pathname.match(/\/ediciones\/(\d+)/)?.[1];
    if (!editionId) return;

    const fileInput = document.getElementById("pages-file-input") as HTMLInputElement;
    const uploadBtn = document.getElementById("pages-upload-btn") as HTMLButtonElement;
    const uploadMsg = document.getElementById("pages-upload-msg") as HTMLParagraphElement;
    const grid = document.getElementById("pages-grid")!;

    if ((window as any)._pagesBound) return;
    (window as any)._pagesBound = true;

    uploadBtn?.addEventListener("click", () => fileInput?.click());

    fileInput?.addEventListener("change", async () => {
      const files = fileInput.files;
      if (!files || files.length === 0) return;

      uploadMsg.classList.remove("hidden");
      uploadMsg.textContent = `Subiendo ${files.length} ${files.length === 1 ? "página" : "páginas"}…`;
      uploadMsg.className = "font-sans text-xs text-triba-brown/60 mt-3";

      const fd = new FormData();
      for (const file of files) {
        fd.append("pages", file);
      }

      try {
        const res = await fetch(`/api/admin/editions/${editionId}/pages`, { method: "POST", body: fd });
        const data = await res.json();
        if (!res.ok) {
          (window as any).adminToast?.(data.error || "Error subiendo páginas", "error");
          uploadMsg.textContent = "";
          uploadMsg.classList.add("hidden");
          return;
        }
        (window as any).adminToast?.(`${data.pages_uploaded} ${data.pages_uploaded === 1 ? "página" : "páginas"} subidas`, "success");
        fileInput.value = "";
        uploadMsg.textContent = "";
        uploadMsg.classList.add("hidden");
        loadPages();
      } catch {
        (window as any).adminToast?.("Error de conexión", "error");
        uploadMsg.textContent = "";
        uploadMsg.classList.add("hidden");
      }
    });

    async function loadPages() {
      try {
        const res = await fetch(`/api/admin/editions/${editionId}/pages`);
        const pages = await res.json();
        if (!Array.isArray(pages)) return;

        if (pages.length === 0) {
          grid.innerHTML = `<p id="pages-empty" class="col-span-full font-sans text-sm text-triba-brown/50 text-center py-8">Todavía no hay páginas. Subí imágenes arriba.</p>`;
          return;
        }

        grid.innerHTML = pages.map((p: any) => `
          <div class="page-card relative group aspect-[3/4] bg-triba-bone rounded border border-triba-black/20 overflow-hidden" data-page-id="${p.id}" data-page-number="${p.page_number}">
            <img src="${escapeHtml(p.image_url)}" alt="${escapeHtml(p.alt_text)}" class="w-full h-full object-cover" />
            <div class="absolute top-1 left-1 bg-triba-black/60 text-triba-white text-[10px] font-heading px-1.5 py-0.5 rounded">${p.page_number}</div>
            <button class="page-delete-btn absolute top-1 right-1 bg-triba-red text-triba-white w-6 h-6 rounded-full text-xs font-heading opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center" data-page-id="${p.id}" data-page-number="${p.page_number}">×</button>
            <div class="absolute bottom-0 inset-x-0 bg-triba-black/50 p-1 opacity-0 group-hover:opacity-100 transition-opacity flex gap-1 justify-center">
              <button class="page-move-btn text-triba-white text-xs font-heading px-1" data-page-id="${p.id}" data-dir="prev">◀</button>
              <button class="page-move-btn text-triba-white text-xs font-heading px-1" data-page-id="${p.id}" data-dir="next">▶</button>
            </div>
          </div>
        `).join("");

        bindPageActions();
      } catch {
        // ignore
      }
    }

    function bindPageActions() {
      document.querySelectorAll<HTMLButtonElement>(".page-delete-btn").forEach((btn) => {
        if (btn.dataset.bound === "1") return;
        btn.dataset.bound = "1";
        btn.addEventListener("click", async () => {
          const pageId = btn.dataset.pageId;
          const pageNum = btn.dataset.pageNumber;
          const confirmed = await (window as any).adminConfirm?.("Eliminar página", `¿Eliminar la página #${pageNum}?`);
          if (!confirmed) return;
          try {
            const res = await fetch(`/api/admin/editions/${editionId}/pages/${pageId}`, { method: "DELETE" });
            if (!res.ok) {
              const data = await res.json().catch(() => ({}));
              (window as any).adminToast?.(data.error || "Error eliminando", "error");
              return;
            }
            (window as any).adminToast?.("Página eliminada", "success");
            loadPages();
          } catch {
            (window as any).adminToast?.("Error de conexión", "error");
          }
        });
      });

      document.querySelectorAll<HTMLButtonElement>(".page-move-btn").forEach((btn) => {
        if (btn.dataset.bound === "1") return;
        btn.dataset.bound = "1";
        btn.addEventListener("click", async () => {
          const cards = [...document.querySelectorAll<HTMLElement>(".page-card")];
          const currentIdx = cards.findIndex((c) => c.dataset.pageId === btn.dataset.pageId);
          if (currentIdx === -1) return;

          const targetIdx = btn.dataset.dir === "prev" ? currentIdx - 1 : currentIdx + 1;
          if (targetIdx < 0 || targetIdx >= cards.length) return;

          const newOrder = cards.map((c) => Number(c.dataset.pageId));
          [newOrder[currentIdx], newOrder[targetIdx]] = [newOrder[targetIdx], newOrder[currentIdx]];

          try {
            const res = await fetch(`/api/admin/editions/${editionId}/pages/reorder`, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ order: newOrder }),
            });
            if (!res.ok) {
              const data = await res.json().catch(() => ({}));
              (window as any).adminToast?.(data.error || "Error reordenando", "error");
              return;
            }
            loadPages();
          } catch {
            (window as any).adminToast?.("Error de conexión", "error");
          }
        });
      });
    }

    function escapeHtml(str: string) {
      const div = document.createElement("div");
      div.textContent = str;
      return div.innerHTML;
    }

    bindPageActions();
  }

  setupPagesManagement();
  document.addEventListener("astro:page-load", setupPagesManagement);
</script>
