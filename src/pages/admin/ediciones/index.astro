---
import AdminLayout from "../../../components/admin/AdminLayout.astro";
import { listEditionsForAdmin } from "../../../lib/admin/editions";

const editions = await listEditionsForAdmin();
---

<AdminLayout title="Ediciones" active="ediciones">
  <div class="flex items-center justify-between mb-6">
    <p class="font-sans text-sm text-triba-brown/70">
      {editions.length} {editions.length === 1 ? "edición" : "ediciones"} publicadas
    </p>
    <a href="/admin/ediciones/nuevo" class="rounded-button bg-triba-red text-triba-white border-2 border-triba-black px-5 py-2.5 font-heading text-xs uppercase tracking-wider hover:scale-[1.02] transition-all">+ Nueva edición</a>
  </div>

  {
    editions.length === 0 ? (
      <div class="bg-triba-cream rounded-xl border-2 border-triba-black p-8 text-center">
        <p class="font-sans text-sm text-triba-brown mb-4">Todavía no hay ediciones.</p>
        <a href="/admin/ediciones/nuevo" class="rounded-button bg-triba-red text-triba-white border-2 border-triba-black px-5 py-2.5 font-heading text-xs uppercase tracking-wider inline-block hover:scale-[1.02] transition-all">Crear la primera</a>
      </div>
    ) : (
      <div class="bg-triba-white rounded-xl border-2 border-triba-black overflow-x-auto">
        <table class="w-full font-sans text-sm">
          <thead class="bg-triba-bone border-b-2 border-triba-black">
            <tr>
              <th class="text-left px-4 py-3 font-heading text-xs uppercase tracking-wider">#</th>
              <th class="text-left px-4 py-3 font-heading text-xs uppercase tracking-wider">Título</th>
              <th class="text-left px-4 py-3 font-heading text-xs uppercase tracking-wider hidden md:table-cell">Publicada</th>
              <th class="text-left px-4 py-3 font-heading text-xs uppercase tracking-wider hidden md:table-cell">Páginas</th>
              <th class="text-left px-4 py-3 font-heading text-xs uppercase tracking-wider">Estado</th>
              <th class="text-right px-4 py-3 font-heading text-xs uppercase tracking-wider">Acciones</th>
            </tr>
          </thead>
          <tbody>
            {editions.map((e) => (
              <tr class="border-b border-triba-black/10 last:border-0 hover:bg-triba-bone/50">
                <td class="px-4 py-3 font-heading text-triba-red">#{e.edition_number}</td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-3">
                    <img src={e.cover_url} alt="" class="w-10 h-14 object-cover rounded border border-triba-black/20" />
                    <div>
                      <p class="font-heading text-sm uppercase tracking-wide">{e.title}</p>
                      {e.badge && <span class="font-sans text-xs text-triba-brown/60">{e.badge}</span>}
                    </div>
                  </div>
                </td>
                <td class="px-4 py-3 text-triba-brown/70 hidden md:table-cell">
                  {new Date(e.published_at).toLocaleDateString("es-AR", { day: "2-digit", month: "short", year: "numeric" })}
                </td>
                <td class="px-4 py-3 text-triba-brown/70 hidden md:table-cell">{e.pages_count}</td>
                <td class="px-4 py-3">
                  {e.featured ? (
                    <span class="inline-block px-2 py-0.5 rounded-full bg-triba-green text-triba-brown font-heading text-[10px] uppercase tracking-wider">Destacada</span>
                  ) : (
                    <span class="inline-block px-2 py-0.5 rounded-full bg-triba-bone text-triba-brown/60 font-heading text-[10px] uppercase tracking-wider">Normal</span>
                  )}
                </td>
                <td class="px-4 py-3 text-right">
                  <a href={`/admin/ediciones/${e.id}`} class="inline-flex items-center justify-center min-h-[44px] min-w-[44px] font-sans text-xs text-triba-red hover:underline">Editar</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )
  }
</AdminLayout>
