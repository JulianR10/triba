---
import AdminLayout from "../../components/admin/AdminLayout.astro";
import { listFeedbackForAdmin } from "../../lib/admin/feedback";

const feedback = await listFeedbackForAdmin();
---

<AdminLayout title="Feedback" active="feedback">
  <p class="font-sans text-sm text-triba-brown/70 mb-6">
    Últimos {feedback.length} {feedback.length === 1 ? "mensaje" : "mensajes"} recibidos. Mostrando los más recientes.
  </p>

  {
    feedback.length === 0 ? (
      <div class="bg-triba-cream rounded-xl border-2 border-triba-black p-8 text-center">
        <p class="font-sans text-sm text-triba-brown">Todavía no hay feedback.</p>
      </div>
    ) : (
      <div class="space-y-3">
        {feedback.map((f) => (
          <div class="bg-triba-white rounded-xl border-2 border-triba-black p-5">
            <div class="flex items-start justify-between gap-3 mb-2">
              <div>
                <p class="font-heading text-sm text-triba-brown">{f.user_email || "Anónimo"}</p>
                <p class="font-sans text-xs text-triba-brown/60">
                  {new Date(f.created_at).toLocaleString("es-AR", { day: "2-digit", month: "short", year: "numeric", hour: "2-digit", minute: "2-digit" })}
                </p>
              </div>
            </div>
            <p class="font-sans text-sm text-triba-brown whitespace-pre-wrap">{f.mensaje}</p>
          </div>
        ))}
      </div>
    )
  }
</AdminLayout>
