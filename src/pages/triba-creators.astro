---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import Input from "../components/Input.astro";
import PatchTitle from "../components/PatchTitle.astro";
---

<Layout title="Triba Creators" description="Sumate como Triba Creator: escribí, diseñá, fotografiá o aportá tu arte a nuestra revista digital. ¡Te esperamos!" canonical="/triba-creators">
  <section class="py-12 md:py-24 px-5 md:px-10 lg:px-20 xl:px-32 2xl:px-48 bg-triba-bone" style="padding-top: max(1rem, var(--nav-height, 64px))">
    <div class="max-w-6xl mx-auto">

      <div class="flex flex-col gap-3 mb-8 pt-8 md:pt-12 reveal-text" data-reveal>
        <PatchTitle content="Sumate como Triba Creator" tag="h1" class="text-4xl md:text-5xl text-triba-brown" />
      </div>

      <div class="flex flex-col md:flex-row gap-8 md:gap-12 items-center mb-12 reveal-stagger" data-reveal>
        <div class="flex-1">
          <img src="/post-triba-creators.webp" alt="Creatividad sin límites" class="w-full h-auto rounded-xl object-cover transition-transform duration-500 hover:scale-[1.03]" />
        </div>
        <div class="flex-1 text-center md:text-left">
          <p class="font-sans text-base text-triba-brown leading-relaxed mb-4">
            A Triba la construimos entre todas y es por eso que todos los meses sumamos nuevas Triba Creator a nuestro equipo de colaboradoras.
          </p>
          <p class="font-sans text-base text-triba-brown leading-relaxed mb-4">
            Podés sumarte como escritora, diseñadora, artista, periodista o lo que quieras :) Siempre que sientas que tenés algo para aportar a este universo sos bienvenida a enviarnos tu propuesta.
          </p>
          <p class="font-sans text-base text-triba-brown leading-relaxed mb-4">
            Evaluamos todas las propuestas y de acuerdo a nuestras necesidades vamos incorporándolas al proyecto.
          </p>
        </div>
      </div>

      <div class="bg-triba-cream rounded-xl border-2 border-triba-black p-6 md:p-10 max-w-2xl mx-auto reveal" data-reveal>
        <h2 class="font-heading text-lg uppercase tracking-wider text-triba-brown mb-6 text-center">Formulario de contacto</h2>
        <form class="space-y-5" id="creators-form">
          <Input label="Nombre" name="nombre" required />
          <Input label="Email" name="email" type="email" required />
          <Input label="País y Ciudad" name="pais" required />
          <div>
            <span class="block font-heading text-xs uppercase tracking-wider text-triba-brown mb-2">¿Qué querés aportar?</span>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
              {["Escritura", "Producción", "Fotografía", "Diseño gráfico", "Arte", "Otros"].map((area) => (
                <label class="flex items-center gap-2 font-sans text-sm text-triba-brown cursor-pointer">
                  <input type="checkbox" name="area" value={area} class="accent-triba-red" />
                  {area}
                </label>
              ))}
            </div>
          </div>
          <Input label="Contanos tu propuesta" name="propuesta" isTextarea required />
          <Input label="¿Dónde podemos ver tu trabajo?" name="trabajo" type="url" placeholder="https://..." />
          <p id="creators-msg" class="font-sans text-sm text-center hidden"></p>
          <Button variant="primary" fullWidth type="submit">Enviar postulación</Button>
        </form>
      </div>

    </div>
  </section>
</Layout>

<script>
  import { supabase } from "../lib/supabase";

  function setup() {
    const form = document.getElementById("creators-form");
    const msg = document.getElementById("creators-msg");

    if (!form) return;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      msg.classList.add("hidden");

      const data = new FormData(form);
      const areas = Array.from(form.querySelectorAll("[name=area]:checked")).map(cb => cb.value);

      const { error } = await supabase.from("creator_applications").insert({
        nombre: data.get("nombre"),
        email: data.get("email"),
        pais: data.get("pais"),
        areas,
        propuesta: data.get("propuesta"),
        trabajo_url: data.get("trabajo") || null,
      });

      if (error) {
        msg.textContent = "Error al enviar. Intentalo de nuevo.";
        msg.className = "font-sans text-sm text-center text-triba-red";
      } else {
        msg.textContent = "¡Gracias por postularte! Te vamos a contactar pronto.";
        msg.className = "font-sans text-sm text-center text-triba-green";
        form.reset();
      }
      msg.classList.remove("hidden");
    });
  }

  setup();
  document.addEventListener("astro:page-load", setup);
</script>
