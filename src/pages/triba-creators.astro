---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import Input from "../components/Input.astro";
---

<Layout title="Triba Creators" description="Sumate como Triba Creator: escribí, diseñá, fotografíá o aportá tu arte a nuestra revista digital. ¡Te esperamos!" canonical="/triba-creators">
  <section class="py-16 md:py-24 px-5 md:px-10 lg:px-20 xl:px-32 2xl:px-48 bg-triba-bone">
    <div class="max-w-6xl mx-auto">

      <div class="bg-triba-pink border-2 border-triba-black px-8 md:px-16 py-4 md:py-5 mb-10 mt-[50px] w-fit mx-auto" style="border-radius: 50%; transform: rotate(-10deg)">
        <h1 class="font-heading text-xl md:text-2xl text-triba-brown uppercase tracking-wide leading-snug text-center whitespace-nowrap">
          Sumate como Triba Creator
        </h1>
      </div>

      <div class="flex flex-col md:flex-row gap-12 items-center mb-16">
        <div class="flex-1">
          <p class="font-sans text-base text-triba-brown leading-relaxed mb-4">
            A Triba la construimos entre todas y es por eso que todos los meses sumamos nuevas Triba Creator a nuestro equipo de colaboradoras.
          </p>
          <p class="font-sans text-base text-triba-brown leading-relaxed mb-4">
            Podes sumarte como escritora, diseñadora, artista, periodista o lo que quieras :) Siempre que sientas que tienes algo para aportar a este universo sos bienvenida a enviarnos tu propuesta.
          </p>
          <p class="font-sans text-base text-triba-brown leading-relaxed">
            Evaluamos todas las propuestas y de acuerdo a nuestras necesidades vamos incorporandolas al proyecto.
          </p>
        </div>
        <div class="flex-1">
          <div class="bg-triba-pink rounded-xl border-2 border-triba-black aspect-square max-w-sm mx-auto flex items-center justify-center">
            <span class="font-heading text-4xl text-triba-pink/30 text-center px-4">Ilustración</span>
          </div>
        </div>
      </div>

      <div class="bg-triba-cream rounded-xl border-2 border-triba-black p-6 md:p-10 max-w-2xl mx-auto">
        <h2 class="font-heading text-lg uppercase tracking-wider text-triba-brown mb-6 text-center">Formulario de contacto</h2>
        <form class="space-y-5" id="creators-form">
          <Input label="Nombre" name="nombre" required />
          <Input label="Email" name="email" type="email" required />
          <Input label="País y Ciudad" name="pais" required />
          <div>
            <span class="block font-heading text-xs uppercase tracking-wider text-triba-brown mb-2">¿Qué querés aportar?</span>
            <div class="grid grid-cols-2 gap-2">
              {["Escritura", "Producción", "Fotografía", "Diseño gráfico", "Arte", "Otros"].map((area) => (
                <label class="flex items-center gap-2 font-sans text-sm text-triba-brown cursor-pointer">
                  <input type="checkbox" name="area" value={area} class="accent-triba-red" />
                  {area}
                </label>
              ))}
            </div>
          </div>
          <Input label="Contanos tu propuesta" name="propuesta" isTextarea required />
          <Input label="¿Dónde podemos ver tu trabajo?" name="trabajo" type="url" placeholder="https://..." />
          <p id="creators-msg" class="font-sans text-sm text-center hidden"></p>
          <Button variant="primary" fullWidth>Enviar postulación</Button>
        </form>
      </div>

    </div>
  </section>
</Layout>

<script>
  import { supabase } from "../lib/supabase";

  const form = document.getElementById("creators-form");
  const msg = document.getElementById("creators-msg");

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    msg.classList.add("hidden");

    const data = new FormData(form);
    const areas = Array.from(form.querySelectorAll("[name=area]:checked")).map(cb => cb.value);

    const { error } = await supabase.from("creator_applications").insert({
      nombre: data.get("nombre"),
      email: data.get("email"),
      pais: data.get("pais"),
      areas,
      propuesta: data.get("propuesta"),
      trabajo_url: data.get("trabajo") || null,
    });

    if (error) {
      msg.textContent = "Error al enviar. Intentalo de nuevo.";
      msg.className = "font-sans text-sm text-center text-triba-red";
    } else {
      msg.textContent = "¡Gracias por postularte! Te vamos a contactar pronto.";
      msg.className = "font-sans text-sm text-center text-triba-green";
      form.reset();
    }
    msg.classList.remove("hidden");
  });
</script>
