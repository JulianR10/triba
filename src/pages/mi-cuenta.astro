---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import PDFViewer from "../components/PDFViewer.tsx";
import PatchTitle from "../components/PatchTitle.astro";

import { createSupabaseServerClient } from "../lib/supabase-server";
import { getEditions, getFeaturedEdition } from "../lib/editions";
import type { Profile, Subscription } from "../lib/types";

const supabase = createSupabaseServerClient(Astro.request);
const { data: { session } } = await supabase.auth.getSession();
const user = session?.user ?? null;

let profile: Profile | null = null;
let subscription: Subscription | null = null;

if (user) {
  const { data: p } = await supabase.from("profiles").select("*").eq("id", user.id).single();
  profile = p;
  if (profile?.subscription_id) {
    const { data: s } = await supabase.from("subscriptions").select("*").eq("id", profile.subscription_id).single();
    subscription = s;
  }
}

const isAdmin = profile?.role === "admin";

const allEditions = await getEditions();
const featuredEdition = await getFeaturedEdition();

const editions = allEditions.map((e) => ({
  id: e.id,
  edition: `#${e.edition_number}`,
  title: e.title,
  description: e.description,
  cover: e.cover_url,
  pdf: e.pdf_url || "#",
  featured: e.featured,
  badge: e.badge,
  slug: `edicion-${e.edition_number}`,
  previewArticle: true,
}));

const featured = editions.find((e) => e.featured) || editions[0];

const checkoutStatus = Astro.url.searchParams.get("checkout");

const displayName = user?.user_metadata?.full_name || user?.email?.split("@")[0] || "lectora";
---

<Layout>
  <section style="padding-top: max(1rem, var(--nav-height, 64px))">
    <div class="max-w-6xl mx-auto">

      {checkoutStatus === "success" && (
        <div data-banner="checkout-success" class="mx-5 md:mx-10 lg:mx-20 xl:mx-32 2xl:mx-48 mb-8 p-4 bg-triba-green/20 border-2 border-triba-green rounded-xl flex items-start justify-between gap-3 reveal" data-reveal>
          <div>
            <p class="font-heading text-sm uppercase tracking-wider text-triba-brown mb-1">¡Suscripción exitosa!</p>
            <p class="font-sans text-sm text-triba-brown">Gracias por sumarte a Triba. Ya podés acceder a la revista desde tu perfil.</p>
          </div>
          <button type="button" data-dismiss-banner class="shrink-0 text-triba-brown hover:text-triba-red text-xl leading-none" aria-label="Cerrar">×</button>
        </div>
      )}

      {
        (subscription?.status === "active") && (
          <>

      <!-- ===== HERO ===== -->
      <div class="relative overflow-hidden rounded-none md:rounded-[32px] bg-gradient-to-br from-triba-pink via-triba-pink/60 to-triba-cream px-5 md:px-14 lg:px-20 py-10 md:py-16 lg:py-20 reveal" data-reveal>
        <div class="flex flex-col md:flex-row gap-8 md:gap-12 items-center">
          <div class="flex-1">
            <p class="font-heading text-sm md:text-base uppercase tracking-[0.2em] text-triba-brown/60 mb-4">Tu edición del mes</p>
            <h1 class="font-heading text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-triba-brown leading-tight mb-2">
              Hola, <span class="text-triba-red">{displayName}</span>
            </h1>
            <div class="mt-6 mb-6">
              <span class="font-heading text-lg uppercase tracking-wider text-triba-red">{featured.edition}</span>
              <h2 class="font-heading text-2xl md:text-3xl text-triba-brown mt-1">{featured.title}</h2>
            </div>
            <p class="font-sans text-sm md:text-base text-triba-brown/80 leading-relaxed mb-8 max-w-lg whitespace-pre-line">
              {featured.description}
            </p>
            <div class="flex flex-wrap gap-4">
              {featured.pdf !== "#" && (
                <Button variant="primary" size="md" href="#visor-revista">Seguir leyendo</Button>
              )}
              {featured.pdf !== "#" && (
                <Button variant="ghost" size="md" href={featured.pdf}>Descargar PDF</Button>
              )}
            </div>
          </div>
          <div class="flex-1 flex justify-center md:justify-end">
            <div class="w-56 sm:w-64 md:w-72 lg:w-80 -rotate-[3deg] hover:rotate-0 transition-transform duration-500">
              <img src={featured.cover} alt={`Portada de ${featured.title}`} fetchpriority="high" class="w-full rounded-xl border-2 border-triba-black shadow-[8px_8px_0px_0px_rgba(0,0,0,0.15)]" />
            </div>
          </div>
        </div>
      </div>

      <!-- Admin banner -->
      {isAdmin && (
        <div class="mt-4 mx-5 md:mx-14 lg:mx-20 mb-8 reveal" data-reveal>
          <div class="bg-triba-green/30 rounded-xl border-2 border-triba-black p-6 text-center max-w-lg mx-auto">
            <p class="font-heading text-xs uppercase tracking-wider text-triba-brown mb-1">Sesión de administración</p>
            <p class="font-sans text-sm text-triba-brown mb-4 text-balance">Estás logueada como <span class="font-bold">admin</span>. El panel de gestión está disponible desde acá.</p>
            <Button variant="primary" href="/admin">Ir al panel de administración</Button>
          </div>
        </div>
      )}

      <!-- ===== COLECCIÓN (staggered cover collage) ===== -->
      <div class="px-5 md:px-14 lg:px-20 mt-12 md:mt-16 mb-12 md:mb-20 reveal" data-reveal>
        <div class="max-w-6xl mx-auto">
          <p class="font-heading text-xs uppercase tracking-[0.25em] text-triba-brown/50 mb-8">Tus tomos</p>

          <!-- Desktop: stacked collage -->
          <div class="hidden md:flex justify-center items-end gap-0 py-8" data-collage-desktop>
            {editions.map((ed, i) => {
              const rotations = [-2.5, 1.8, -1.2, 2.2, -1.8, 1.5, -2.0, 2.5];
              const rot = rotations[i % rotations.length];
              const z = editions.length - i;
              const ml = i === 0 ? 0 : -12;
              return (
                <a
                  href={`/revista/${ed.slug}`}
                  class="relative transition-all duration-400 hover:z-30 group block"
                  style={`margin-left: ${ml}px; z-index: ${z}; transform: rotate(${rot}deg);`}
                >
                  <div class="w-44 lg:w-52 xl:w-56 aspect-[3/4] rounded-xl overflow-hidden border-2 border-triba-black shadow-lg transition-all duration-400 group-hover:rotate-0 group-hover:scale-105 group-hover:shadow-2xl">
                    <img src={ed.cover} alt={`Portada ${ed.edition}`} class="w-full h-full object-cover" loading="lazy" />
                  </div>
                  <p class="font-heading text-xs uppercase tracking-wider text-triba-brown/60 text-center mt-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300">{ed.edition}</p>
                </a>
              );
            })}
          </div>

          <!-- Mobile: snap-horizontal scroll -->
          <div class="md:hidden" data-collage-mobile>
            <div class="flex gap-3 overflow-x-auto snap-x snap-mandatory scrollbar-hide pb-4 -mx-5 px-5">
              {editions.map((ed, i) => {
                const rotations = [-2, 1.5, -1, 2, -1.5, 1, -2.5, 2];
                const rot = rotations[i % rotations.length];
                return (
                  <a href={`/revista/${ed.slug}`} class="snap-center shrink-0 w-[70vw] max-w-[240px] block" style={`transform: rotate(${rot}deg);`}>
                    <div class="aspect-[3/4] rounded-xl overflow-hidden border-2 border-triba-black shadow-lg">
                      <img src={ed.cover} alt={`Portada ${ed.edition}`} class="w-full h-full object-cover" loading="lazy" />
                    </div>
                    <p class="font-heading text-xs uppercase tracking-wider text-triba-brown/60 text-center mt-2">{ed.edition}</p>
                  </a>
                );
              })}
            </div>
            <!-- Dots -->
            <div class="flex justify-center gap-2 mt-4" data-dots>
              {editions.map((_, i) => (
                <span class="w-2 h-2 rounded-full bg-triba-brown/20 transition-colors duration-300" data-dot={i}></span>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- ===== VISOR ===== -->
      <div class="bg-triba-cream w-full px-5 md:px-14 lg:px-20 xl:px-32 2xl:px-48 py-12 md:py-20">
        <div class="max-w-6xl mx-auto">
          {featured.pdf !== "#" && (
          <div id="visor-revista" style="scroll-margin-top: calc(var(--nav-height, 64px) + 1rem)" class="reveal" data-reveal>
            <PatchTitle content={`${featured.edition} ${featured.title}`} tag="h2" class="text-2xl md:text-3xl text-triba-brown mb-8" />

            <div class="-mx-5 md:mx-0">
              <PDFViewer pdfUrl={featured.pdf} client:visible />
            </div>

            <p class="font-heading text-xs uppercase tracking-[0.2em] text-triba-brown/40 text-center mt-6">Deslizá o usá los botones para pasar las páginas</p>
          </div>
          )}
        </div>
      </div>

      <!-- ===== FEEDBACK ===== -->
      <div class="px-5 md:px-14 lg:px-20 py-12 md:py-16">
        <div class="max-w-lg mx-auto reveal" data-reveal>
          <h2 class="font-heading text-2xl md:text-3xl text-triba-brown text-center mb-8">Contanos qué te pareció</h2>

          <form id="feedback-form">
            <textarea
              name="feedback"
              rows="4"
              placeholder="¿Qué te gustó? ¿Qué cambiarías?..."
              maxlength="2000"
              class="w-full px-5 py-4 rounded-xl border-2 border-triba-black bg-triba-white font-sans text-sm text-triba-brown outline-none focus:border-triba-red transition-colors resize-none mb-3"
            ></textarea>
            <div class="flex items-center justify-between gap-4">
              <span id="feedback-counter" class="font-sans text-xs text-triba-brown/50">0 / 2000</span>
              <Button variant="primary" type="submit">Enviar</Button>
            </div>
            <p id="feedback-msg" class="font-sans text-sm text-center mt-3 hidden"></p>
          </form>
        </div>
      </div>

        </>
        )
      }

      {
        !(subscription?.status === "active") && (
          <div class="max-w-lg mx-auto mt-10 text-center reveal px-5" data-reveal>
            <div class="bg-triba-cream rounded-xl border-2 border-triba-black p-8">
              <h2 class="font-heading text-base uppercase tracking-wider text-triba-brown mb-2">Todavía no tenés suscripción</h2>
              <p class="font-sans text-sm text-triba-brown/70 mb-6 leading-relaxed">Suscribite para acceder a la revista completa, el archivo histórico y la descarga PDF.</p>
              <Button variant="primary" href="/suscribirme">Suscribirme</Button>
            </div>
          </div>
        )
      }

    </div>
  </section>
</Layout>

<script>
  import { supabase } from "../lib/supabase";

  function setup() {

  // --- Poll subscription after checkout ---
  var pollInterval: ReturnType<typeof setInterval> | null = null;
  var searchParams = new URLSearchParams(window.location.search);
  if (searchParams.get("checkout") === "success") {
    var attempts = 0;
    var maxAttempts = 12;

    pollInterval = setInterval(async function () {
      attempts++;
      if (attempts > maxAttempts) {
        if (pollInterval) clearInterval(pollInterval);
        return;
      }

      try {
        var { data: { session } } = await supabase.auth.getSession();
        if (!session) return;

        var res = await fetch("/api/subscription-status", {
          headers: { Authorization: "Bearer " + session.access_token },
        });
        var data = await res.json();
        if (data.role === "subscriber") {
          if (pollInterval) clearInterval(pollInterval);
          window.location.reload();
        }
      } catch {
        /* retry */
      }
    }, 3000);
  }

  // --- Mobile collage dots ---
  var collageScroll = document.querySelector("[data-collage-mobile] .overflow-x-auto");
  var dots = document.querySelectorAll("[data-dot]");
  if (collageScroll && dots.length) {
    var updateDots = function () {
      var scrollLeft = collageScroll.scrollLeft;
      var scrollWidth = collageScroll.scrollWidth - collageScroll.clientWidth;
      if (scrollWidth <= 0) { dots.forEach(function (d) { d.classList.add("bg-triba-brown/60"); d.classList.remove("bg-triba-brown/20"); }); return; }
      var ratio = scrollLeft / scrollWidth;
      var active = Math.round(ratio * (dots.length - 1));
      dots.forEach(function (d, i) {
        d.classList.toggle("bg-triba-brown/60", i === active);
        d.classList.toggle("bg-triba-brown/20", i !== active);
      });
    };
    collageScroll.addEventListener("scroll", updateDots);
    updateDots();
  }

  // --- Feedback form ---
  const fbForm = document.getElementById("feedback-form");
  const fbMsg = document.getElementById("feedback-msg");
  const fbTextarea = fbForm?.querySelector("textarea[name=feedback]") as HTMLTextAreaElement | null;
  const fbCounter = document.getElementById("feedback-counter");
  const fbBtn = fbForm?.querySelector("button[type=submit]") as HTMLButtonElement | null;

  const updateCounter = () => {
    if (!fbTextarea || !fbCounter) return;
    const len = fbTextarea.value.length;
    fbCounter.textContent = len + " / 2000";
    fbCounter.className = len > 2000
      ? "font-sans text-xs text-triba-red"
      : "font-sans text-xs text-triba-brown/50";
    if (fbBtn) fbBtn.disabled = len === 0 || len > 2000;
  };

  if (fbTextarea && fbCounter) {
    fbTextarea.addEventListener("input", updateCounter);
    updateCounter();
  }

  if (fbForm) {
    fbForm.addEventListener("submit", async (e) => {
      e.preventDefault();
      fbMsg.classList.add("hidden");
      fbMsg.className = "font-sans text-sm text-center mt-3 hidden";

      var { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        fbMsg.textContent = "Debés iniciar sesión para enviar feedback";
        fbMsg.className = "font-sans text-sm text-center text-triba-red mt-3";
        fbMsg.classList.remove("hidden");
        return;
      }

      const mensaje = fbTextarea?.value;
      if (fbBtn) {
        fbBtn.disabled = true;
        fbBtn.textContent = "Enviando...";
      }

      try {
        const res = await fetch("/api/feedback", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Authorization: "Bearer " + session.access_token,
          },
          body: JSON.stringify({ mensaje }),
        });

        const data = await res.json().catch(() => ({}));

        if (res.status === 429) {
          fbMsg.textContent = data.error || "Esperá un momento antes de enviar otro feedback";
          fbMsg.className = "font-sans text-sm text-center text-triba-red mt-3";
        } else if (!res.ok) {
          fbMsg.textContent = data.error || "Error al enviar. Intentalo de nuevo.";
          fbMsg.className = "font-sans text-sm text-center text-triba-red mt-3";
        } else {
          fbMsg.textContent = "¡Gracias por tu feedback!";
          fbMsg.className = "font-sans text-sm text-center text-triba-green mt-3";
          if (fbTextarea) fbTextarea.value = "";
          updateCounter();
        }
      } catch (err) {
        fbMsg.textContent = "Error de conexión. Intentalo de nuevo.";
        fbMsg.className = "font-sans text-sm text-center text-triba-red mt-3";
      } finally {
        if (fbBtn) {
          fbBtn.disabled = false;
          fbBtn.textContent = "Enviar";
        }
        fbMsg.classList.remove("hidden");
      }
    });
  }

  // Banner dismiss
  document.querySelectorAll("[data-dismiss-banner]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const banner = btn.closest("[data-banner]");
      if (banner) banner.style.display = "none";
    });
  });

  }

  setup();
  document.addEventListener("astro:page-load", setup);
</script>
