---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import MagazineCarousel from "../components/MagazineCarousel.astro";
import MagazineSlider from "../components/MagazineSlider.astro";
import PageFlipViewer from "../components/PageFlipViewer.tsx";
import PatchTitle from "../components/PatchTitle.astro";

const title = "Revista";
const description = "Explorá las ediciones de Triba, nuestra revista digital mensual. Leé online, descargá PDF y descubrí artículos de cultura, arte e identidad.";
const canonical = "/revista";

import { getEditions, getFeaturedEdition, getEditionPages } from "../lib/editions";
const allEditions = await getEditions();
const featuredEdition = await getFeaturedEdition();
const featuredPages = featuredEdition ? await getEditionPages(featuredEdition.id) : [];

const previewPages = featuredPages.map((p) => ({
  src: p.image_url,
  alt: p.alt_text,
}));

const editions = allEditions.map((e) => ({
  id: e.id,
  edition: `#${e.edition_number}`,
  title: e.title,
  description: e.description,
  cover: e.cover_url,
  pdf: e.pdf_url || "#",
  featured: e.featured,
  badge: e.badge,
  previewArticle: e.edition_number === (featuredEdition?.edition_number || 3),
}));

const featured = editions.find((e) => e.featured) || editions[0];
---

<Layout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Periodical",
    "name": "Triba",
    "description": description,
    "url": "https://comunidadtriba.com/revista",
    "issn": "",
    "publisher": {
      "@type": "Organization",
      "name": "Triba",
      "url": "https://comunidadtriba.com"
    },
    "inLanguage": "es",
    "numberOfIssues": allEditions.length,
  })} />
  <section class="py-12 md:py-24 px-5 md:px-10 lg:px-20 xl:px-32 2xl:px-48 bg-triba-bone" style="padding-top: max(1rem, var(--nav-height, 64px))">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col gap-3 mb-8 pt-8 md:pt-12 reveal-text" data-reveal>
        <PatchTitle content="Nuestra revista" tag="h1" class="text-4xl md:text-5xl text-triba-brown" />
      </div>

      <!-- Bloque 1: Edición destacada -->
      <div class="flex flex-col md:flex-row gap-8 md:gap-12 lg:gap-16 mb-8 md:mb-20 reveal-stagger" data-reveal>
        <div class="flex-1 flex flex-col justify-center order-1 text-center md:text-left">
          <p id="featured-desc" class="font-sans text-base md:text-lg text-triba-brown leading-relaxed mb-8">
            {featured.description}
          </p>
          <div class="flex flex-wrap justify-center md:justify-start gap-4">
            {featuredPages.length > 0 && (
              <Button variant="primary" href="#visor-revista">Leer aquí</Button>
            )}
            <Button variant="default" id="featured-cta" href={featuredEdition?.pdf_url || "/suscribirme"}>
              {featuredEdition?.pdf_url ? "LA QUIERO!" : "Suscribirme"}
            </Button>
          </div>
        </div>
        <div class="hidden md:block flex-1 order-2 md:order-2">
          <div class="relative max-w-sm mx-auto md:mx-auto">
            <img id="featured-cover" src={featured.cover} alt={`Portada de ${featured.title}`} fetchpriority="high" class="w-full rounded-xl border-2 border-triba-black shadow-lg hover:scale-[1.02] transition-transform duration-500" />
            <span id="featured-badge" class={"absolute -top-3 -right-3 bg-triba-red text-triba-white font-heading text-xs uppercase px-3 py-1 rounded-full border-2 border-triba-black shadow-[2px_2px_0_rgba(0,0,0,0.15)] " + (featured.badge ? "" : "hidden")}>
              {featured.badge}
            </span>
          </div>
        </div>
      </div>

      <!-- Bloque 1.5: Slider mobile con las 3 portadas (primera con sticker) -->
      <div class="md:hidden mb-12 reveal" data-reveal>
        <MagazineSlider
          items={editions.map((ed) => ({
            id: ed.id,
            cover: ed.cover,
            badge: ed.id === featured.id ? ed.badge : null,
          }))}
          selectedId={featured.id}
        />
      </div>

      <!-- Bloque 2: Carrusel de ediciones (solo desktop) -->
      <div class="relative bg-white w-full px-5 md:px-10 lg:px-20 py-8 md:py-14 rounded-[20px] mx-auto mb-12 md:mb-20 reveal hidden md:block" data-reveal>
        <div class="max-w-6xl mx-auto">
          <MagazineCarousel editions={editions} selectedId={featured.id} />
        </div>
      </div>

      <!-- Bloque 3: Vista previa de artículo -->
      {previewPages.length > 0 && (
      <div id="visor-revista" class="flex flex-col md:flex-row gap-8 md:gap-12 lg:gap-16 reveal-stagger" style="scroll-margin-top: calc(var(--nav-height, 64px) + 1rem)" data-reveal>
        <div class="flex-1 order-2 md:order-1">
          <PageFlipViewer pages={previewPages} client:visible />
        </div>
        <div class="flex-1 flex flex-col justify-center order-1 md:order-2 text-center md:text-left">
          <PatchTitle tag="h2" class="mb-4 text-2xl md:text-3xl" lines={[
            [
              { t: "¡ECHALE", bg: "bg-triba-cream", tx: "text-triba-black" },
              { t: "UN", bg: "bg-triba-white", tx: "text-triba-black" },
              { t: "VISTAZO", bg: "bg-triba-pink", tx: "text-triba-black" },
              { t: "A", bg: "bg-triba-blue/20", tx: "text-triba-black" },
              { t: "UNO", bg: "bg-triba-bone", tx: "text-triba-black" },
            ],
            [
              { t: "DE", bg: "bg-triba-light-cream", tx: "text-triba-black" },
              { t: "NUESTROS", bg: "bg-triba-cream", tx: "text-triba-black" },
              { t: "ARTICULOS", bg: "bg-triba-green", tx: "text-triba-black" },
              { t: "!", bg: "bg-triba-pink", tx: "text-triba-black" },
            ],
          ]} />
          <p class="font-sans text-base md:text-lg text-triba-brown leading-relaxed mb-6">
            Como sabemos que no se puede desear lo que no se conoce, queremos regalarte un artículo gratis de la última edición de nuestra revista.
          </p>
          <p class="font-sans text-base md:text-lg text-triba-brown leading-relaxed mb-8">
            Si disfrutas de tu lectura, te esperamos en la suscripción!
          </p>
          <div class="flex justify-center md:justify-start">
            <Button variant="primary" href="/suscribirme">Suscribirme</Button>
          </div>
        </div>
      </div>
      )}
    </div>
  </section>
</Layout>

<script>
  function setup() {
    var featuredCover = document.getElementById("featured-cover");
    var featuredBadge = document.getElementById("featured-badge");
    var featuredDesc = document.getElementById("featured-desc");
    var featuredCta = document.getElementById("featured-cta");
    var carousel = document.querySelector("[data-carousel]");

    var featuredEl = document.querySelector("[data-featured]");
    var currentId = featuredEl ? parseInt(featuredEl.dataset.editionId || "0") : 0;

    function readEdition(card) {
      return {
        id: parseInt(card.dataset.editionId),
        edition: card.dataset.editionName,
        title: card.dataset.title,
        description: card.dataset.description,
        cover: card.dataset.cover,
        pdf: card.dataset.pdf,
        badge: card.dataset.badge || null,
      };
    }

    function setActiveCard(id) {
      if (!carousel) return;
      var cards = carousel.querySelectorAll("[data-edition-id]");
      for (var i = 0; i < cards.length; i++) {
        var cardId = parseInt(cards[i].dataset.editionId);
        var isSelected = cardId === id;
        cards[i].setAttribute("aria-selected", isSelected);
      }
    }

    function selectEdition(id) {
      if (id === currentId) return;
      var card = carousel.querySelector('[data-edition-id="' + id + '"]');
      if (!card) return;
      var ed = readEdition(card);
      currentId = id;

      if (featuredCover) {
        featuredCover.src = ed.cover;
        featuredCover.alt = "Portada de " + ed.title;
      }
      if (featuredCta) {
        featuredCta.href = ed.pdf && ed.pdf !== "#" ? ed.pdf : "/suscribirme";
        featuredCta.textContent = ed.pdf && ed.pdf !== "#" ? "LA QUIERO!" : "Suscribirme";
      }
      if (featuredDesc) {
        featuredDesc.textContent = ed.description || "";
      }

      if (ed.badge) {
        if (featuredBadge) {
          featuredBadge.textContent = ed.badge;
          featuredBadge.classList.remove("hidden");
        }
      } else {
        if (featuredBadge) {
          featuredBadge.classList.add("hidden");
        }
      }

      setActiveCard(id);
    }

    if (carousel) {
      carousel.addEventListener("click", function (e) {
        var card = e.target.closest("[data-edition-id]");
        if (card) {
          var id = parseInt(card.dataset.editionId);
          selectEdition(id);
        }
      });
    }
  }

  setup();
  document.addEventListener("astro:page-load", setup);
</script>
